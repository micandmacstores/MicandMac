{% comment %}
  Snippet: filter-bar
  Usage: {% render 'filter-bar', collection: collection, results: results %}
  Filter by skin type, ingredient, price + sort + active pills + result count
{% endcomment %}

{%- assign sort_by = collection.sort_by | default: collection.default_sort_by -%}

<div class="filter-bar" id="FilterBar">
  <div class="filter-bar__top">
    <div class="filter-bar__controls">

      <!-- Filter toggle (mobile) -->
      <button class="filter-bar__mobile-toggle btn btn--secondary btn--sm" id="FilterToggle" aria-expanded="false" aria-controls="FilterDrawer">
        <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
          <line x1="4" y1="6" x2="20" y2="6"/><line x1="8" y1="12" x2="20" y2="12"/><line x1="12" y1="18" x2="20" y2="18"/>
        </svg>
        Filters
        {%- if collection.filters.size > 0 -%}
          {%- assign active_count = 0 -%}
          {%- for filter in collection.filters -%}
            {%- assign active_count = active_count | plus: filter.active_values.size -%}
          {%- endfor -%}
          {%- if active_count > 0 -%}
            <span class="filter-bar__active-count">{{ active_count }}</span>
          {%- endif -%}
        {%- endif -%}
      </button>

    </div>
  </div>

  <!-- Desktop inline filters -->
  <div class="filter-bar__filters" id="FilterDrawer">
    {%- for filter in collection.filters -%}
      <details class="filter-group" id="FilterGroup-{{ forloop.index }}">
        <summary class="filter-group__trigger">
          {{ filter.label }}
          {%- if filter.active_values.size > 0 -%}
            <span class="filter-group__count">({{ filter.active_values.size }})</span>
          {%- endif -%}
          <svg width="12" height="8" viewBox="0 0 12 8" fill="none" aria-hidden="true">
            <path d="M1 1L6 6L11 1" stroke="currentColor" stroke-width="1.5" stroke-linecap="round"/>
          </svg>
        </summary>
        <div class="filter-group__options">
          {%- if filter.type == 'price_range' -%}
            <div class="filter-price-range">
              <div class="filter-price-range__inputs">
                <span>₹</span>
                <input
                  type="number"
                  name="{{ filter.min_value.param_name }}"
                  id="FilterMinPrice"
                  class="form-input filter-price-range__input"
                  value="{{ filter.min_value.value | divided_by: 100 | floor }}"
                  min="0"
                  max="{{ filter.range_max | divided_by: 100 | ceil }}"
                  placeholder="Min"
                  aria-label="Minimum price"
                >
                <span>-</span>
                <span>₹</span>
                <input
                  type="number"
                  name="{{ filter.max_value.param_name }}"
                  id="FilterMaxPrice"
                  class="form-input filter-price-range__input"
                  value="{{ filter.max_value.value | divided_by: 100 | ceil }}"
                  min="0"
                  max="{{ filter.range_max | divided_by: 100 | ceil }}"
                  placeholder="Max"
                  aria-label="Maximum price"
                >
                <button type="button" class="btn btn--primary btn--sm" id="FilterPriceApply">Go</button>
              </div>
            </div>
          {%- else -%}
            <ul class="filter-group__list">
              {%- for value in filter.values -%}
                <li>
                  <a
                    href="{{ value.url_to_add }}"
                    class="filter-option {% if value.active %}is-active{% endif %} {% if value.count == 0 %}is-disabled{% endif %}"
                    data-filter-value="{{ value.param_name }}={{ value.value | url_encode }}"
                    aria-label="{{ value.label }} ({{ value.count }} products)"
                  >
                    <span class="filter-option__check {% if value.active %}is-checked{% endif %}" aria-hidden="true"></span>
                    {{ value.label }}
                    <span class="filter-option__count">({{ value.count }})</span>
                  </a>
                </li>
              {%- endfor -%}
            </ul>
          {%- endif -%}
        </div>
      </details>
    {%- endfor -%}
  </div>

  <!-- Active filter pills -->
  {%- liquid
    assign has_active = false
    for filter in collection.filters
      if filter.active_values.size > 0
        assign has_active = true
      endif
    endfor
  -%}
  {%- if has_active -%}
    <div class="filter-bar__active-pills">
      {%- for filter in collection.filters -%}
        {%- for value in filter.active_values -%}
          <a href="{{ value.url_to_remove }}" class="filter-pill">
            {{ value.label }}
            <svg width="10" height="10" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" aria-hidden="true">
              <path d="M18 6L6 18M6 6l12 12"/>
            </svg>
          </a>
        {%- endfor -%}
      {%- endfor -%}
      <a href="{{ collection.url }}" class="filter-pill filter-pill--clear">Clear all</a>
    </div>
  {%- endif -%}
</div>

<style>
.filter-bar { margin-bottom: var(--space-6); }

.filter-bar__top {
  display: flex;
  align-items: center;
  justify-content: space-between;
  gap: var(--space-4);
  padding-bottom: var(--space-4);
  border-bottom: 1px solid var(--color-beige);
  margin-bottom: var(--space-4);
}

.filter-bar__count {
  font-size: var(--text-sm);
  color: var(--color-text-light);
}

.filter-bar__controls {
  display: flex;
  align-items: center;
  gap: var(--space-3);
}

.filter-bar__mobile-toggle { display: none; }

.filter-bar__active-count {
  display: inline-flex;
  align-items: center;
  justify-content: center;
  width: 18px;
  height: 18px;
  background: var(--color-forest);
  color: var(--color-white);
  font-size: 10px;
  border-radius: 50%;
  font-weight: 700;
}

.filter-bar__sort-select {
  padding: var(--space-2) var(--space-4);
  font-size: var(--text-sm);
  min-width: 180px;
}

.filter-bar__filters {
  display: flex;
  flex-wrap: wrap;
  gap: var(--space-3);
}

/* Filter groups */
.filter-group {
  position: relative;
}

.filter-group__trigger {
  display: flex;
  align-items: center;
  gap: var(--space-2);
  padding: var(--space-2) var(--space-4);
  border: 1.5px solid var(--color-beige);
  border-radius: var(--radius-pill);
  font-size: var(--text-sm);
  font-weight: 500;
  color: var(--color-text-dark);
  cursor: pointer;
  white-space: nowrap;
  list-style: none;
  transition: all var(--transition-fast);
  user-select: none;
}

.filter-group__trigger::-webkit-details-marker { display: none; }
.filter-group[open] .filter-group__trigger { border-color: var(--color-forest); color: var(--color-forest); }
.filter-group__trigger svg { transition: transform var(--transition-fast); }
.filter-group[open] .filter-group__trigger svg { transform: rotate(180deg); }

.filter-group__count {
  color: var(--color-forest);
  font-size: var(--text-xs);
}

.filter-group__options {
  position: absolute;
  top: calc(100% + 8px);
  left: 0;
  z-index: var(--z-above);
  background: var(--color-white);
  border: 1px solid var(--color-beige);
  border-radius: var(--radius-lg);
  box-shadow: var(--shadow-lg);
  padding: var(--space-4);
  min-width: 200px;
  animation: fadeIn 0.15s ease;
}

.filter-group__list { display: flex; flex-direction: column; gap: var(--space-2); }

.filter-option {
  display: flex;
  align-items: center;
  gap: var(--space-2);
  padding: var(--space-2) 0;
  font-size: var(--text-sm);
  color: var(--color-text-mid);
  cursor: pointer;
  transition: color var(--transition-fast);
  text-decoration: none;
}

.filter-option:hover { color: var(--color-text-dark); }
.filter-option.is-active { color: var(--color-forest); }
.filter-option.is-disabled { opacity: 0.4; pointer-events: none; }

.filter-option__check {
  width: 16px;
  height: 16px;
  border: 1.5px solid var(--color-beige);
  border-radius: var(--radius-sm);
  flex-shrink: 0;
  transition: all var(--transition-fast);
  position: relative;
}

.filter-option__check.is-checked {
  background: var(--color-forest);
  border-color: var(--color-forest);
}

.filter-option__check.is-checked::after {
  content: '';
  position: absolute;
  top: 1px; left: 4px;
  width: 5px; height: 9px;
  border: 2px solid white;
  border-top: none; border-left: none;
  transform: rotate(45deg);
}

.filter-option__count { color: var(--color-text-light); font-size: var(--text-xs); margin-left: auto; }

/* Price range */
.filter-price-range__inputs {
  display: flex;
  align-items: center;
  gap: var(--space-2);
  flex-wrap: wrap;
}

.filter-price-range__input {
  width: 80px;
  padding: var(--space-2) var(--space-3);
  font-size: var(--text-sm);
}

/* Active pills */
.filter-bar__active-pills {
  display: flex;
  flex-wrap: wrap;
  gap: var(--space-2);
  margin-top: var(--space-3);
}

.filter-pill {
  display: inline-flex;
  align-items: center;
  gap: var(--space-2);
  padding: var(--space-1) var(--space-3);
  background: var(--color-beige);
  border-radius: var(--radius-pill);
  font-size: var(--text-xs);
  font-weight: 500;
  color: var(--color-text-dark);
  text-decoration: none;
  transition: all var(--transition-fast);
}

.filter-pill:hover { background: var(--color-forest); color: var(--color-white); }
.filter-pill--clear { color: var(--color-forest); }

@media (max-width: 767px) {
  .filter-bar__mobile-toggle { display: inline-flex; }
  .filter-bar__filters {
    display: none;
    flex-direction: column;
    position: fixed;
    top: 0; left: 0; right: 0; bottom: 0;
    z-index: var(--z-modal);
    background: var(--color-white);
    padding: var(--space-6);
    overflow-y: auto;
  }
  .filter-bar__filters.is-open { display: flex; }
  .filter-group__options { position: static; box-shadow: none; border: none; padding: 0; }
}
</style>
