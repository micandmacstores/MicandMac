{% comment %}
  Snippet: product-form
  Usage: {% render 'product-form', product: product, section: section %}
  Clean CTA - no qty stepper, Add to Bag primary, Buy Now secondary, minimal wishlist.
{% endcomment %}

{%- liquid
  assign current_variant = product.selected_or_first_available_variant
  assign sold_out = false
  unless current_variant.available
    assign sold_out = true
  endunless
-%}

{%- form 'product', product, id: 'ProductForm', class: 'product-form', novalidate: 'novalidate' -%}
  <input type="hidden" name="id" value="{{ current_variant.id }}" id="ProductVariantId">

  <div class="product-form__utils-row">
    <!-- Quantity Stepper -->
    <div class="product-form__qty">
      <button type="button" class="product-form__qty-btn" data-qty-change="-1" aria-label="Decrease quantity">
        <svg width="12" height="12" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round"><line x1="5" y1="12" x2="19" y2="12"/></svg>
      </button>
      <input type="number" name="quantity" id="Quantity-{{ section.id }}" value="1" min="1" class="product-form__qty-input" readonly>
      <button type="button" class="product-form__qty-btn" data-qty-change="1" aria-label="Increase quantity">
        <svg width="12" height="12" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round"><line x1="12" y1="5" x2="12" y2="19"/><line x1="5" y1="12" x2="19" y2="12"/></svg>
      </button>
    </div>

    <!-- Save (Bookmark) Button -->
    <button
      type="button"
      class="product-form__util-btn product-form__util-btn--wishlist"
      aria-label="Save to wishlist"
      data-wishlist-toggle
      data-product-handle="{{ product.handle }}"
    >
      <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round">
        <path d="M19 21l-7-5-7 5V5a2 2 0 0 1 2-2h10a2 2 0 0 1 2 2z"/>
      </svg>
    </button>

    <!-- Share Button -->
    <button
      type="button"
      class="product-form__util-btn product-form__util-btn--share"
      aria-label="Share product"
      data-share-button
      data-share-title="{{ product.title | escape }}"
      data-share-url="{{ shop.url }}{{ product.url }}"
    >
      <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round">
        <path d="M4 12v8a2 2 0 0 0 2 2h12a2 2 0 0 0 2-2v-8"/><polyline points="16 6 12 2 8 6"/><line x1="12" y1="2" x2="12" y2="15"/>
      </svg>
    </button>
  </div>

  <!-- Variant Picker (only if product has variants) -->
  {%- unless product.has_only_default_variant -%}
    <div class="product-form__variants" id="ProductVariants">
      {%- for option in product.options_with_values -%}
        <div class="product-form__option">
          <p class="product-form__option-label">
            {{ option.name }}: <strong id="OptionValue-{{ forloop.index }}">{{ option.selected_value }}</strong>
          </p>
          <div class="product-form__option-pills">
            {%- for value in option.values -%}
              {%- assign is_selected = false -%}
              {%- if option.selected_value == value -%}{%- assign is_selected = true -%}{%- endif -%}
              <button
                type="button"
                class="variant-pill {% if is_selected %}is-selected{% endif %}"
                data-option-index="{{ forloop.parentloop.index0 }}"
                data-option-value="{{ value | escape }}"
                aria-pressed="{{ is_selected }}"
                aria-label="{{ option.name }}: {{ value }}"
              >
                {{ value }}
              </button>
            {%- endfor -%}
          </div>
        </div>
      {%- endfor -%}
    </div>
  {%- endunless -%}

  <!-- CTA Buttons -->
  <div class="product-form__actions">
    {%- if sold_out -%}
      <button type="button" class="btn btn--secondary btn--full btn--lg product-form__atc" disabled>
        Sold Out
      </button>
      {%- if section.settings.show_notify_me -%}
        <div class="product-form__notify">
          <p>Get notified when this is back in stock:</p>
          {%- form 'contact', id: 'NotifyForm' -%}
            <input type="hidden" name="contact[body]" value="Back in stock: {{ product.title }}">
            <div class="product-form__notify-row">
              <input type="email" name="contact[email]" class="form-input" placeholder="your@email.com" required aria-label="Email">
              <button type="submit" class="btn btn--primary btn--sm">Notify Me</button>
            </div>
          {%- endform -%}
        </div>
      {%- endif -%}
    {%- else -%}
      <div class="product-form__actions-row">
        <!-- Primary: Add to Bag -->
        <button
          type="submit"
          name="add"
          class="btn btn--primary product-form__atc"
          id="ProductATC"
          data-atc
          data-variant-id="{{ current_variant.id }}"
        >
          <svg width="17" height="17" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" aria-hidden="true">
            <path d="M6 2L3 6v14a2 2 0 0 0 2 2h14a2 2 0 0 0 2-2V6l-3-4z"/><line x1="3" y1="6" x2="21" y2="6"/><path d="M16 10a4 4 0 0 1-8 0"/>
          </svg>
          Add to Bag
        </button>

        <!-- Secondary: Buy Now -->
        {%- if section.settings.show_buy_now -%}
          <button
            type="button"
            class="product-form__buy-now"
            id="ProductBuyNow"
            data-buy-now
            data-variant-id="{{ current_variant.id }}"
          >
            Buy Now
          </button>
        {%- endif -%}
      </div>
    {%- endif -%}
  </div>
{%- endform -%}

<script>
(function() {
  const form = document.querySelector('#ProductForm');
  if (!form) return;

  // Quantity Stepper
  const qtyInput = form.querySelector('.product-form__qty-input');
  const qtyBtns = form.querySelectorAll('.product-form__qty-btn');

  qtyBtns.forEach(btn => {
    btn.addEventListener('click', () => {
      const change = parseInt(btn.dataset.qtyChange);
      const newVal = Math.max(1, parseInt(qtyInput.value) + change);
      qtyInput.value = newVal;
    });
  });

  // Share Button
  const shareBtn = form.querySelector('[data-share-button]');
  if (shareBtn) {
    shareBtn.addEventListener('click', async () => {
      const shareData = {
        title: shareBtn.dataset.shareTitle,
        url: shareBtn.dataset.shareUrl
      };

      if (navigator.share) {
        try {
          await navigator.share(shareData);
        } catch (err) {
          console.error('Share failed:', err);
        }
      } else {
        // Fallback: Copy to clipboard
        try {
          await navigator.clipboard.writeText(shareData.url);
          const originalLabel = shareBtn.getAttribute('aria-label');
          shareBtn.setAttribute('aria-label', 'Link copied!');
          shareBtn.classList.add('is-copied');
          setTimeout(() => {
            shareBtn.setAttribute('aria-label', originalLabel);
            shareBtn.classList.remove('is-copied');
          }, 2000);
        } catch (err) {
          console.error('Copy failed:', err);
        }
      }
    });
  }
})();
</script>
