{%- comment -%}
  meta-tags.liquid
  Page-type-aware SEO: title, description, canonical, OG tags, Twitter card.
  Fixes blank-title bug that caused Google to show "– MIC & MAC".
{%- endcomment -%}

<meta charset="utf-8">
<meta http-equiv="X-UA-Compatible" content="IE=edge">
<meta name="viewport" content="width=device-width,initial-scale=1">

{%- liquid
  assign brand = shop.name

  case template.name
    when 'index'
      assign seo_title = brand | append: ' | Natural Artisan Skincare — Glowing Bars & Lip Care'
      assign seo_desc  = 'Mic & Mac — Lab-certified artisan skincare crafted with natural ingredients. Discover glowing bars, nourishing lip care & more. Free shipping over ₹999.'
    when 'product'
      assign seo_title = product.title | append: ' | ' | append: brand
      assign seo_desc  = product.description | strip_html | truncatewords: 25
      if seo_desc == blank
        assign seo_desc = 'Shop ' | append: product.title | append: ' at Mic & Mac — premium natural skincare. Free shipping over ₹999.'
      endif
    when 'collection'
      assign seo_title = collection.title | append: ' | ' | append: brand
      assign seo_desc  = collection.description | strip_html | truncatewords: 25
      if seo_desc == blank
        assign seo_desc = 'Shop ' | append: collection.title | append: ' at Mic & Mac — premium natural skincare. Free shipping over ₹999.'
      endif
    when 'blog'
      assign seo_title = blog.title | append: ' | ' | append: brand
      assign seo_desc  = 'Skincare tips, ingredient guides and wellness stories from the Mic & Mac team.'
    when 'article'
      assign seo_title = article.title | append: ' | ' | append: brand
      assign seo_desc  = article.excerpt_or_content | strip_html | truncatewords: 25
    when 'page'
      assign seo_title = page.title | append: ' | ' | append: brand
      assign seo_desc  = page.content | strip_html | truncatewords: 25
      if seo_desc == blank
        assign seo_desc = 'Mic & Mac — Premium natural skincare made with lab-certified ingredients.'
      endif
    when 'search'
      assign seo_title = 'Search | ' | append: brand
      assign seo_desc  = 'Search Mic & Mac for natural skincare products, glowing bars, lip care and more.'
    when 'cart'
      assign seo_title = 'Your Bag | ' | append: brand
      assign seo_desc  = 'Review and checkout your Mic & Mac order.'
    when '404'
      assign seo_title = 'Page Not Found | ' | append: brand
      assign seo_desc  = 'The page you are looking for does not exist. Browse our full range of natural skincare.'
    else
      assign seo_title = page_title | default: brand
      assign seo_desc  = page_description | default: 'Mic & Mac — Premium natural skincare made with lab-certified ingredients.'
  endcase

  if current_page > 1
    assign seo_title = seo_title | append: ' — Page ' | append: current_page
  endif

  assign og_url  = canonical_url | default: request.origin
  assign og_type = 'website'
  if template.name == 'product'
    assign og_type = 'product'
  elsif template.name == 'article'
    assign og_type = 'article'
  endif
-%}

<!-- ── Primary SEO ──────────────────────────────────── -->
<title>{{ seo_title | escape }}</title>
<meta name="description" content="{{ seo_desc | escape }}">
<link rel="canonical" href="{{ canonical_url }}">
<meta name="robots" content="index, follow">

<!-- ── Open Graph ───────────────────────────────────── -->
<meta property="og:site_name"   content="{{ brand | escape }}">
<meta property="og:type"        content="{{ og_type }}">
<meta property="og:title"       content="{{ seo_title | escape }}">
<meta property="og:description" content="{{ seo_desc | escape }}">
<meta property="og:url"         content="{{ og_url }}">
{%- if template.name == 'product' and product.featured_image -%}
  <meta property="og:image"            content="https:{{ product.featured_image | image_url: width: 1200 }}">
  <meta property="og:image:secure_url" content="https:{{ product.featured_image | image_url: width: 1200 }}">
  <meta property="og:image:width"      content="1200">
  <meta property="og:image:height"     content="1200">
{%- elsif template.name == 'article' and article.image -%}
  <meta property="og:image"            content="https:{{ article.image | image_url: width: 1200 }}">
  <meta property="og:image:secure_url" content="https:{{ article.image | image_url: width: 1200 }}">
{%- elsif page_image -%}
  <meta property="og:image"            content="https:{{ page_image | image_url: width: 1200 }}">
  <meta property="og:image:secure_url" content="https:{{ page_image | image_url: width: 1200 }}">
{%- endif -%}

<!-- ── Twitter / X Card ─────────────────────────────── -->
<meta name="twitter:card"        content="summary_large_image">
<meta name="twitter:title"       content="{{ seo_title | escape }}">
<meta name="twitter:description" content="{{ seo_desc | escape }}">

<!-- ── Structured Data (Product pages) ──────────────── -->
{%- if template.name == 'product' -%}
  <script type="application/ld+json">{{ product | structured_data }}</script>
  <meta property="og:price:amount"   content="{{ product.price | money_without_currency | strip_html }}">
  <meta property="og:price:currency" content="{{ cart.currency.iso_code }}">
{%- endif -%}
