{% comment %} Auth Modal — Two-step: Login + Register (no page redirect) {% endcomment %}

<div id="AuthModal" class="auth-modal" aria-hidden="true" role="dialog" aria-modal="true" aria-label="Sign in to your account">
  <div class="auth-modal__backdrop" id="AuthModalBackdrop"></div>

  <div class="auth-modal__panel">

    <!-- LEFT: Brand Layer -->
    <div class="auth-modal__brand">
      <div class="auth-modal__brand-inner">
        <a href="{{ routes.root_url }}" class="auth-modal__brand-logo">
          <img src="{{ 'MicandMac_Monogram.webp' | asset_url }}" alt="Mic &amp; Mac" width="40" height="40">
          <span>MIC &amp; MAC</span>
        </a>
        <div class="auth-modal__brand-copy">
          <h2 class="auth-modal__brand-headline">Pure care,<br><em>thoughtfully made.</em></h2>
          <p class="auth-modal__brand-subtext">Handcrafted skincare rooted in nature &amp; ritual.</p>
        </div>
        <div class="auth-modal__brand-decoration" aria-hidden="true">
          <div class="auth-modal__circle auth-modal__circle--1"></div>
          <div class="auth-modal__circle auth-modal__circle--2"></div>
        </div>
      </div>
    </div>

    <!-- RIGHT: Auth Form -->
    <div class="auth-modal__form-side">
      <button class="auth-modal__close" id="AuthModalClose" aria-label="Close">
        <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round">
          <path d="M18 6L6 18M6 6l12 12"/>
        </svg>
      </button>

      <!-- ═══ STEP 1: SIGN IN ═══ -->
      <div class="auth-modal__step" id="AuthStepLogin">
        <div class="auth-modal__form-header">
          <h3 class="auth-modal__title">Welcome back.</h3>
          <p class="auth-modal__subtitle">Continue with your email to access your account.</p>
        </div>

        {%- form 'customer_login', id: 'AuthLoginForm', novalidate: 'novalidate' -%}
          <input type="hidden" name="return_to" value="/pages/my-account">
          {%- if form.errors -%}
            <div class="auth-modal__error" role="alert">
              <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><circle cx="12" cy="12" r="10"/><line x1="12" y1="8" x2="12" y2="12"/><line x1="12" y1="16" x2="12.01" y2="16"/></svg>
              {{ form.errors | default_errors }}
            </div>
          {%- endif -%}

          <div class="auth-modal__field">
            <label for="AuthEmailInput" class="auth-modal__label">Email</label>
            <input type="email" id="AuthEmailInput" name="customer[email]" class="auth-modal__input" autocomplete="email" placeholder="your@email.com" required>
          </div>

          <div class="auth-modal__field">
            <div class="auth-modal__label-row">
              <label for="AuthPasswordInput" class="auth-modal__label">Password</label>
              <a href="{{ routes.account_recover_url }}" class="auth-modal__forgot">Forgot?</a>
            </div>
            <div class="auth-modal__input-wrapper">
              <input type="password" id="AuthPasswordInput" name="customer[password]" class="auth-modal__input" autocomplete="current-password" placeholder="••••••••" required>
              <button type="button" class="password-toggle" data-password-toggle aria-label="Show password">
                <svg class="eye-open" width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M1 12s4-8 11-8 11 8 11 8-4 8-11 8-11-8-11-8z"/><circle cx="12" cy="12" r="3"/></svg>
                <svg class="eye-closed" width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" style="display:none;"><path d="M17.94 17.94A10.07 10.07 0 0 1 12 20c-7 0-11-8-11-8a18.45 18.45 0 0 1 5.06-5.94M9.9 4.24A9.12 9.12 0 0 1 12 4c7 0 11 8 11 8a18.5 18.5 0 0 1-2.16 3.19m-6.72-1.07a3 3 0 1 1-4.24-4.24"></path><line x1="1" y1="1" x2="23" y2="23"></line></svg>
              </button>
            </div>
          </div>

          <button type="submit" class="auth-modal__cta">
            Continue
            <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round"><path d="M5 12h14M12 5l7 7-7 7"/></svg>
          </button>

          <p class="auth-modal__trust">
            <svg width="12" height="12" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M12 22s8-4 8-10V5l-8-3-8 3v7c0 6 8 10 8 10z"/></svg>
            Secure login. Your data is safe with us.
          </p>
        {%- endform -%}

        <div class="auth-modal__social-separator"><span>or</span></div>
        <a href="/account/login?no_modal=true" class="auth-modal__google-btn">
          <svg class="auth-modal__google-icon" viewBox="0 0 24 24" width="18" height="18">
            <path d="M22.56 12.25c0-.78-.07-1.53-.2-2.25H12v4.26h5.92c-.26 1.37-1.04 2.53-2.21 3.31v2.77h3.57c2.08-1.92 3.28-4.74 3.28-8.09z" fill="#4285F4"/>
            <path d="M12 23c2.97 0 5.46-.98 7.28-2.66l-3.57-2.77c-.98.66-2.23 1.06-3.71 1.06-2.86 0-5.29-1.93-6.16-4.53H2.18v2.84C3.99 20.53 7.7 23 12 23z" fill="#34A853"/>
            <path d="M5.84 14.09c-.22-.66-.35-1.36-.35-2.09s.13-1.43.35-2.09V7.06H2.18C1.43 8.55 1 10.22 1 12s.43 3.45 1.18 4.94l2.85-2.22.81-.63z" fill="#FBBC05"/>
            <path d="M12 5.38c1.62 0 3.06.56 4.21 1.64l3.15-3.15C17.45 2.09 14.97 1 12 1 7.7 1 3.99 3.47 2.18 7.06l3.66 2.84c.87-2.6 3.3-4.52 6.16-4.52z" fill="#EA4335"/>
          </svg>
          Continue with Google
        </a>

        <div class="auth-modal__divider"><span>New here?</span></div>
        <!-- Switch to Register step — NO page redirect -->
        <button type="button" class="auth-modal__alt-cta" id="SwitchToRegister">Create an account</button>
      </div>

      <!-- ═══ STEP 2: CREATE ACCOUNT ═══ -->
      <div class="auth-modal__step" id="AuthStepRegister" style="display:none;">
        <div class="auth-modal__form-header">
          <button type="button" class="auth-modal__back" id="SwitchToLogin" aria-label="Back to sign in">
            <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round"><path d="M19 12H5M12 5l-7 7 7 7"/></svg>
            Back
          </button>
          <h3 class="auth-modal__title">Create account.</h3>
          <p class="auth-modal__subtitle">Join us to save your wishlist &amp; track orders.</p>
        </div>

        {%- form 'create_customer', id: 'AuthRegisterForm', novalidate: 'novalidate' -%}
          <input type="hidden" name="return_to" value="/pages/my-account">
          {%- if form.errors -%}
            <div class="auth-modal__error" role="alert">
              <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><circle cx="12" cy="12" r="10"/><line x1="12" y1="8" x2="12" y2="12"/><line x1="12" y1="16" x2="12.01" y2="16"/></svg>
              {{ form.errors | default_errors }}
            </div>
          {%- endif -%}

          <div style="display:grid;grid-template-columns:1fr 1fr;gap:10px;">
            <div class="auth-modal__field">
              <label for="AuthRegFirstName" class="auth-modal__label">First name</label>
              <input type="text" id="AuthRegFirstName" name="customer[first_name]" class="auth-modal__input" autocomplete="given-name" required>
            </div>
            <div class="auth-modal__field">
              <label for="AuthRegLastName" class="auth-modal__label">Last name</label>
              <input type="text" id="AuthRegLastName" name="customer[last_name]" class="auth-modal__input" autocomplete="family-name" required>
            </div>
          </div>

          <div class="auth-modal__field">
            <label for="AuthRegEmail" class="auth-modal__label">Email</label>
            <input type="email" id="AuthRegEmail" name="customer[email]" class="auth-modal__input" autocomplete="email" placeholder="your@email.com" required>
          </div>

          <div class="auth-modal__field">
            <label for="AuthRegPassword" class="auth-modal__label">Password</label>
            <div class="auth-modal__input-wrapper">
              <input type="password" id="AuthRegPassword" name="customer[password]" class="auth-modal__input" autocomplete="new-password" placeholder="Min. 8 characters" required minlength="8">
              <button type="button" class="password-toggle" data-password-toggle aria-label="Show password">
                <svg class="eye-open" width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M1 12s4-8 11-8 11 8 11 8-4 8-11 8-11-8-11-8z"/><circle cx="12" cy="12" r="3"/></svg>
                <svg class="eye-closed" width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" style="display:none;"><path d="M17.94 17.94A10.07 10.07 0 0 1 12 20c-7 0-11-8-11-8a18.45 18.45 0 0 1 5.06-5.94M9.9 4.24A9.12 9.12 0 0 1 12 4c7 0 11 8 11 8a18.5 18.5 0 0 1-2.16 3.19m-6.72-1.07a3 3 0 1 1-4.24-4.24"></path><line x1="1" y1="1" x2="23" y2="23"></line></svg>
              </button>
            </div>
          </div>

          <button type="submit" class="auth-modal__cta">
            Create Account
            <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round"><path d="M5 12h14M12 5l7 7-7 7"/></svg>
          </button>

          <p class="auth-modal__trust">
            <svg width="12" height="12" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M12 22s8-4 8-10V5l-8-3-8 3v7c0 6 8 10 8 10z"/></svg>
            We never share your data.
          </p>
        {%- endform -%}

        <div class="auth-modal__social-separator"><span>or</span></div>
        <a href="/account/login?no_modal=true" class="auth-modal__google-btn">
          <svg class="auth-modal__google-icon" viewBox="0 0 24 24" width="18" height="18">
            <path d="M22.56 12.25c0-.78-.07-1.53-.2-2.25H12v4.26h5.92c-.26 1.37-1.04 2.53-2.21 3.31v2.77h3.57c2.08-1.92 3.28-4.74 3.28-8.09z" fill="#4285F4"/>
            <path d="M12 23c2.97 0 5.46-.98 7.28-2.66l-3.57-2.77c-.98.66-2.23 1.06-3.71 1.06-2.86 0-5.29-1.93-6.16-4.53H2.18v2.84C3.99 20.53 7.7 23 12 23z" fill="#34A853"/>
            <path d="M5.84 14.09c-.22-.66-.35-1.36-.35-2.09s.13-1.43.35-2.09V7.06H2.18C1.43 8.55 1 10.22 1 12s.43 3.45 1.18 4.94l2.85-2.22.81-.63z" fill="#FBBC05"/>
            <path d="M12 5.38c1.62 0 3.06.56 4.21 1.64l3.15-3.15C17.45 2.09 14.97 1 12 1 7.7 1 3.99 3.47 2.18 7.06l3.66 2.84c.87-2.6 3.3-4.52 6.16-4.52z" fill="#EA4335"/>
          </svg>
          Continue with Google
        </a>
      </div>

    </div>
  </div>
</div>
