{% comment %}
  Snippet: product-gallery
  Usage: {% render 'product-gallery', product: product %}
  Desktop: vertical thumbnail rail (left) + sticky main image (right)
  Mobile: horizontal swipe strip below main image
{% endcomment %}

{%- assign media_count = product.media.size -%}

<div class="product-gallery" id="ProductGallery" data-media-count="{{ media_count }}">

  {%- if media_count > 1 -%}
    <!-- Vertical thumbnail rail (desktop) / horizontal strip (mobile) -->
    <div class="product-gallery__rail" id="GalleryRail">
      {%- for media in product.media -%}
        <button
          class="product-gallery__thumb {% if forloop.first %}is-active{% endif %}"
          data-index="{{ forloop.index0 }}"
          aria-label="View image {{ forloop.index }}"
        >
          <img
            src="{{ media | image_url: width: 160 }}"
            alt="{{ media.alt | escape | default: product.title }}"
            width="150"
            height="150"
            loading="lazy"
          >
        </button>
      {%- endfor -%}
    </div>
  {%- endif -%}

  <!-- Main image -->
  <div class="product-gallery__main" id="GalleryMain">
    {%- for media in product.media -%}
      <div
        class="product-gallery__slide {% if forloop.first %}is-active{% endif %}"
        data-index="{{ forloop.index0 }}"
        id="GallerySlide-{{ forloop.index0 }}"
      >
        {%- if media.media_type == 'video' -%}
          {{ media | video_tag: autoplay: false, loop: false, muted: false, controls: true, class: 'product-gallery__video' }}
        {%- elsif media.media_type == 'external_video' -%}
          {{ media | external_video_tag: class: 'product-gallery__video' }}
        {%- else -%}
          <div class="product-gallery__skeleton"></div>
          <img
            src="{{ media | image_url: width: 1200 }}"
            srcset="
              {{ media | image_url: width: 600  }} 600w,
              {{ media | image_url: width: 900  }} 900w,
              {{ media | image_url: width: 1200 }} 1200w,
              {{ media | image_url: width: 1600 }} 1600w
            "
            sizes="(max-width: 767px) 100vw, 55vw"
            alt="{{ media.alt | escape | default: product.title }}"
            width="1200"
            height="1200"
            loading="{% if forloop.first %}eager{% else %}lazy{% endif %}"
            class="product-gallery__img"
            onload="this.previousElementSibling.style.display='none'"
          >
        {%- endif -%}
      </div>
    {%- endfor -%}

    <!-- Counter pill -->
    {%- if media_count > 1 -%}
      <div class="product-gallery__counter" id="GalleryCounter">
        <span id="GalleryCurrentNum">1</span> / {{ media_count }}
      </div>
    {%- endif -%}

    <!-- Zoom Close Button (Hidden by default) -->
    <button class="product-gallery__zoom-close" id="GalleryZoomClose" aria-label="Close zoom">
      <svg width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round"><path d="M18 6L6 18M6 6l12 12"/></svg>
    </button>
  </div>

</div>

<script>
(function () {
  var gallery = document.getElementById('ProductGallery');
  if (!gallery) return;

  var slides = gallery.querySelectorAll('.product-gallery__slide');
  var thumbs = gallery.querySelectorAll('.product-gallery__thumb');
  var counter = document.getElementById('GalleryCurrentNum');
  var current = 0;

  function goTo(idx) {
    slides[current].classList.remove('is-active');
    thumbs[current] && thumbs[current].classList.remove('is-active');
    current = idx;
    slides[current].classList.add('is-active');
    thumbs[current] && thumbs[current].classList.add('is-active');
    if (counter) counter.textContent = current + 1;
    // scroll thumb into view on vertical rail
    thumbs[current] && thumbs[current].scrollIntoView({ behavior: 'smooth', block: 'nearest', inline: 'nearest' });
  }

  thumbs.forEach(function (btn, i) {
    btn.addEventListener('click', function () { goTo(i); });
    btn.addEventListener('mouseenter', function () { goTo(i); });
  });

  // Touch swipe on main image (mobile)
  var main = document.getElementById('GalleryMain');
  var touchStartX = 0;
  main.addEventListener('touchstart', function (e) { touchStartX = e.changedTouches[0].screenX; }, { passive: true });
  main.addEventListener('touchend', function (e) {
    var dx = e.changedTouches[0].screenX - touchStartX;
    if (Math.abs(dx) < 40) return;
    if (dx < 0 && current < slides.length - 1) goTo(current + 1);
    if (dx > 0 && current > 0) goTo(current - 1);
  });
  // Click to Zoom Logic (In-place Pan Zoom)
  slides.forEach(function(slide) {
    var img = slide.querySelector('.product-gallery__img');
    if (!img) return;

    slide.addEventListener('click', function() {
      if (window.innerWidth < 768) return; 
      
      var isZoomed = gallery.classList.toggle('is-zoomed');
      
      if (!isZoomed) {
        img.style.transform = '';
        img.style.transformOrigin = '';
      }
    });

    slide.addEventListener('mousemove', function(e) {
      if (!gallery.classList.contains('is-zoomed')) return;

      var rect = slide.getBoundingClientRect();
      var x = ((e.clientX - rect.left) / rect.width) * 100;
      var y = ((e.clientY - rect.top) / rect.height) * 100;

      img.style.transformOrigin = x + '% ' + y + '%';
    });

    slide.addEventListener('mouseleave', function() {
      if (gallery.classList.contains('is-zoomed')) {
        gallery.classList.remove('is-zoomed');
        img.style.transform = '';
        img.style.transformOrigin = '';
      }
    });
  });

  document.addEventListener('keydown', function(e) {
    if (e.key === 'Escape' && gallery.classList.contains('is-zoomed')) {
      gallery.classList.remove('is-zoomed');
      slides.forEach(function(s) {
        var i = s.querySelector('.product-gallery__img');
        if (i) {
          i.style.transform = '';
          i.style.transformOrigin = '';
        }
      });
    }
  });
})();
</script>

