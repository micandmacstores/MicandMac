{%- style -%}
  .section-{{ section.id }}-padding {
    padding-top: {{ section.settings.padding_top | times: 0.75 | round: 0 }}px;
    padding-bottom: {{ section.settings.padding_bottom | times: 0.75 | round: 0 }}px;
  }

  @media screen and (min-width: 750px) {
    .section-{{ section.id }}-padding {
      padding-top: {{ section.settings.padding_top }}px;
      padding-bottom: {{ section.settings.padding_bottom }}px;
    }
  }

  .ingredients-section-wrapper {
    background: transparent;
    overflow: hidden;
  }

  .ingredients-title {
    text-align: center;
    font-family: var(--font-heading-family, serif);
    font-size: 2.5rem;
    font-weight: 400;
    margin-bottom: 3.5rem;
    letter-spacing: -0.01em;
    color: #111;
  }

  .ingredients-grid {
    display: grid;
    grid-template-columns: repeat(4, 1fr);
    gap: 32px;
  }

  .ingredient-card {
    text-align: left;
    transition: transform 0.4s cubic-bezier(0.25, 0.46, 0.45, 0.94);
    display: flex;
    flex-direction: column;
    border-radius: 16px;
    background: transparent;
    padding: 24px;
    height: 100%;
  }

  .ingredient-card:hover {
    transform: translateY(-4px);
  }

  .ingredient-card.highlight {
    background: transparent;
  }

  .ingredient-image-wrapper {
    width: 100%;
    aspect-ratio: 1;
    display: flex;
    align-items: center;
    justify-content: center;
    margin-bottom: 24px;
  }

  .ingredient-image {
    width: 100%;
    height: 100%;
    object-fit: contain;
    transition: transform 0.6s cubic-bezier(0.25, 0.46, 0.45, 0.94);
  }

  .ingredient-card:hover .ingredient-image {
    transform: scale(1.05);
  }

  .ingredient-card h3 {
    font-family: var(--font-heading-family);
    font-size: 1.25rem;
    font-weight: 600;
    margin-bottom: 12px;
    color: #1a1a1a;
  }

  .ingredient-card p {
    font-family: var(--font-body-family);
    font-size: 0.95rem;
    line-height: 1.6;
    color: #555;
    margin-bottom: 24px;
    flex-grow: 1;
  }

  .ingredient-link {
    font-family: var(--font-body-family);
    font-size: 0.85rem;
    font-weight: 600;
    color: #111;
    text-decoration: none;
    letter-spacing: 0.02em;
    position: relative;
    display: inline-flex;
    align-items: center;
    align-self: flex-start;
  }

  .ingredient-link::after {
    content: '';
    position: absolute;
    bottom: -2px;
    left: 0;
    width: 100%;
    height: 1px;
    background-color: #111;
    transform: scaleX(0);
    transform-origin: bottom right;
    transition: transform 0.3s ease;
  }

  .ingredient-link:hover::after {
    transform: scaleX(1);
    transform-origin: bottom left;
  }

  @media (max-width: 1024px) {
    .ingredients-grid {
      grid-template-columns: repeat(2, 1fr);
      gap: 24px;
    }
  }

  @media (max-width: 768px) {
    .ingredients-title {
      font-size: 2rem;
      margin-bottom: 2rem;
    }

    /* Horizontal scroll strip on mobile */
    .ingredients-grid {
      display: flex;
      flex-direction: row;
      overflow-x: auto;
      gap: 12px;
      padding-bottom: 12px;
      scroll-snap-type: x mandatory;
      -webkit-overflow-scrolling: touch;
      scrollbar-width: none;
    }
    .ingredients-grid::-webkit-scrollbar { display: none; }

    .ingredient-card {
      min-width: 200px;
      max-width: 200px;
      flex-shrink: 0;
      scroll-snap-align: start;
      padding: 16px;
    }

    .ingredient-card h3 {
      font-size: 1rem;
    }

    .ingredient-card p {
      font-size: 0.85rem;
      margin-bottom: 16px;
    }

    .ingredient-link {
      font-size: 0.75rem;
    }
  }
{%- endstyle -%}

{%- liquid
  assign max_ingredients = section.settings.max_ingredients
  assign has_any_ingredient = false
  for i in (1..max_ingredients)
    assign name_key = 'ingredient_' | append: i | append: '_name'
    assign ing_name = product.metafields.custom[name_key]
    if ing_name != blank
      assign has_any_ingredient = true
      break
    endif
  endfor
-%}

<div class="ingredients-section-wrapper section-{{ section.id }}-padding" style="padding-left: 2rem; padding-right: 2rem;">
  <div class="page-width">
    {% if section.settings.title != blank %}
      <h2 class="ingredients-title">{{ section.settings.title }}</h2>
    {% endif %}

    <div class="ingredients-grid">

      {%- if has_any_ingredient -%}
        {%- for i in (1..max_ingredients) -%}
          {%- assign name_key  = 'ingredient_' | append: i | append: '_name' -%}
          {%- assign desc_key  = 'ingredient_' | append: i | append: '_description' -%}
          {%- assign image_key = 'ingredient_' | append: i | append: '_image' -%}
          {%- assign link_key  = 'ingredient_' | append: i | append: '_link' -%}

          {%- assign ing_name  = product.metafields.custom[name_key] -%}
          {%- assign ing_desc  = product.metafields.custom[desc_key] -%}
          {%- assign ing_image = product.metafields.custom[image_key] -%}
          {%- assign ing_link  = product.metafields.custom[link_key] -%}

          {%- if ing_name != blank or ing_image != blank -%}
            <div class="ingredient-card {% if forloop.first %}highlight{% endif %}">

              <div class="ingredient-image-wrapper">
                {%- if ing_image != blank -%}
                  <img
                    class="ingredient-image"
                    src="{{ ing_image | image_url: width: 500 }}"
                    alt="{{ ing_name | escape }}"
                    loading="lazy"
                    width="500"
                    height="{{ 500 | divided_by: ing_image.aspect_ratio | ceil }}"
                  >
                {%- else -%}
                  {{ 'image' | placeholder_svg_tag: 'ingredient-image' }}
                {%- endif -%}
              </div>

              {%- if ing_name != blank -%}
                <h3>{{ ing_name }}</h3>
              {%- endif -%}

              {%- if ing_desc != blank -%}
                <p>{{ ing_desc | newline_to_br }}</p>
              {%- endif -%}

              {%- if ing_link != blank -%}
                <a href="{{ ing_link }}" class="ingredient-link">read more →</a>
              {%- endif -%}

            </div>
          {%- endif -%}
        {%- endfor -%}

      {%- else -%}
        {%- comment -%} Placeholder cards shown in Theme Editor before metafields are filled {%- endcomment -%}
        <div class="ingredient-card highlight">
          <div class="ingredient-image-wrapper">{{ 'image' | placeholder_svg_tag: 'ingredient-image' }}</div>
          <h3>Ingredient 1</h3>
          <p>Add this product's ingredients via Shopify Admin → Products → Metafields.</p>
        </div>
        <div class="ingredient-card">
          <div class="ingredient-image-wrapper">{{ 'image' | placeholder_svg_tag: 'ingredient-image' }}</div>
          <h3>Ingredient 2</h3>
          <p>Each product can have its own unique ingredients without needing separate templates.</p>
        </div>
        <div class="ingredient-card">
          <div class="ingredient-image-wrapper">{{ 'image' | placeholder_svg_tag: 'ingredient-image' }}</div>
          <h3>Ingredient 3</h3>
          <p>Set up metafield definitions in Settings → Custom Data → Products.</p>
        </div>
        <div class="ingredient-card">
          <div class="ingredient-image-wrapper">{{ 'image' | placeholder_svg_tag: 'ingredient-image' }}</div>
          <h3>Ingredient 4</h3>
          <p>Use keys like ingredient_1_name, ingredient_1_image in the custom namespace.</p>
        </div>
      {%- endif -%}

    </div>
  </div>
</div>

{% schema %}
{
  "name": "Product Ingredients",
  "tag": "section",
  "class": "section",
  "settings": [
    {
      "type": "paragraph",
      "content": "⚡ Ingredients are loaded per-product from metafields. Go to Shopify Admin → Products → [Product] → Metafields to set ingredient_1_name, ingredient_1_image, etc."
    },
    {
      "type": "text",
      "id": "title",
      "label": "Section Title",
      "default": "Key Ingredients"
    },
    {
      "type": "range",
      "id": "max_ingredients",
      "min": 1,
      "max": 6,
      "step": 1,
      "label": "Max ingredients to display",
      "default": 4
    },
    {
      "type": "range",
      "id": "padding_top",
      "min": 0,
      "max": 100,
      "step": 4,
      "unit": "px",
      "label": "Top padding",
      "default": 80
    },
    {
      "type": "range",
      "id": "padding_bottom",
      "min": 0,
      "max": 100,
      "step": 4,
      "unit": "px",
      "label": "Bottom padding",
      "default": 80
    }
  ],
  "presets": [
    {
      "name": "Product Ingredients"
    }
  ]
}
{% endschema %}
