{%- comment -%}
  ╔══════════════════════════════════════════════════════════════╗
  ║  MIC & MAC — CINEMATIC HERO  (v3.0 — rebuilt from scratch)  ║
  ║                                                              ║
  ║  Layout: Full-bleed video · left-aligned content block       ║
  ║  Overlay: Asymmetric gradient — dark left / open right       ║
  ║  CTAs: Primary pill + Ghost secondary                        ║
  ║  Fallback: Static image → CSS gradient                       ║
  ║  Mobile: Center-aligned, stronger overlay, single CTA        ║
  ╚══════════════════════════════════════════════════════════════╝
{%- endcomment -%}

{%- style -%}
/* ── Reset & Scope ───────────────────────────────────────────── */
.cine-hero *,
.cine-hero *::before,
.cine-hero *::after {
  box-sizing: border-box;
  margin: 0;
  padding: 0;
}

/* ── Shell ───────────────────────────────────────────────────── */
.cine-hero {
  position: relative;
  width: 100%;
  height: 100svh;
  min-height: 560px;
  max-height: 1000px;
  overflow: hidden;
  background: var(--mm-dark-espresso);
  display: flex;
  align-items: center;
  margin-top: 0 !important;
}

/* ── Video / Image Layer ─────────────────────────────────────── */
.cine-hero__media {
  position: absolute;
  inset: 0;
  z-index: 0;
}

.cine-hero__video,
.cine-hero__img {
  width: 100%;
  height: 100%;
  object-fit: cover;
  object-position: center;
  display: block;
  transform: scale(1.05);
}

/* Subtle slow-zoom on static image fallback */
.cine-hero__img {
  animation: cine-zoom 18s ease-in-out infinite alternate;
}

@keyframes cine-zoom {
  from { transform: scale(1.05);    }
  to   { transform: scale(1.11); }
}

/* ── Cinematic Overlay ───────────────────────────────────────── */
/* Left darker (text readable) → transparent right (product fully visible) */
.cine-hero__overlay {
  position: absolute;
  inset: 0;
  z-index: 1;
  background: linear-gradient(
    to right,
    rgba(20, 10, 10, 0.45) 0%,
    rgba(20, 10, 10, 0.25) 40%,
    transparent 70%
  );
}

/* Gradient overlay at the top to ensure the transparent white navbar is always readable */
.cine-hero__overlay::before {
  content: "";
  position: absolute;
  top: 0;
  left: 0;
  right: 0;
  height: 220px;
  background: linear-gradient(to bottom, rgba(15, 5, 5, 0.6) 0%, rgba(15, 5, 5, 0) 100%);
  z-index: 2;
  pointer-events: none;
}

/* ── Content Block ───────────────────────────────────────────── */
.cine-hero__content {
  position: relative;
  z-index: 10;
  width: 100%;
  max-width: var(--container-wide, 1440px);
  margin: 0 auto;
  padding: 0 var(--space-8, 2rem);
  display: flex;
  flex-direction: column;
  align-items: flex-start;
  gap: 0;
  transform: translateY(15%);
}

@media screen and (min-width: 768px) {
  .cine-hero__content {
    padding: 0 60px;
  }
}

@media screen and (min-width: 1280px) {
  .cine-hero__content {
    padding: 0 80px;
  }
}

/* ── Tagline ─────────────────────────────────────────────────── */
.cine-hero__tagline {
  font-family: var(--font-body, 'Inter', sans-serif);
  font-size: 0.6875rem;          /* 11px */
  font-weight: 600;
  letter-spacing: 0.22em;
  text-transform: uppercase;
  color: var(--mm-champagne-gold, #D4AF37);
  margin-bottom: 1.25rem;
  opacity: 0;
  transform: translateY(16px);
  animation: cine-rise 0.7s ease 0.2s forwards;
}

/* ── Headline ────────────────────────────────────────────────── */
.cine-hero__heading {
  font-family: var(--font-display, 'Cormorant Garamond', serif);
  font-size: clamp(1.8rem, 5vw, 2.6rem);
  font-weight: 300;
  line-height: 1.1;
  letter-spacing: -0.015em;
  color: var(--mm-soft-blush, #F3E8E4);
  max-width: 560px;
  margin-bottom: 1.5rem;
  opacity: 0;
  transform: translateY(20px);
  animation: cine-rise 0.8s ease 0.38s forwards;
}

/* Italic last word / phrase accent */
.cine-hero__heading em {
  font-style: italic;
  color: var(--mm-champagne-gold, #D4AF37);
  font-weight: 300;
}

/* ── Supporting Text ─────────────────────────────────────────── */
.cine-hero__body {
  font-family: var(--font-body, 'Inter', sans-serif);
  font-size: 0.9375rem;
  line-height: 1.65;
  color: rgba(243, 232, 228, 0.72);
  max-width: 400px;
  margin-bottom: 2.25rem;
  opacity: 0;
  transform: translateY(16px);
  animation: cine-rise 0.7s ease 0.55s forwards;
}

/* ── CTA Group ───────────────────────────────────────────────── */
.cine-hero__ctas {
  display: flex;
  flex-direction: row;
  align-items: center;
  flex-wrap: wrap;
  gap: 1.5rem;
  opacity: 0;
  transform: translateY(14px);
  animation: cine-rise 0.7s ease 0.72s forwards;
}

/* Primary CTA */
.cine-hero__cta-primary {
  display: inline-flex;
  align-items: center;
  gap: 8px;
  background: rgba(255, 255, 255, 0.15);
  backdrop-filter: blur(12px);
  -webkit-backdrop-filter: blur(12px);
  border: 1px solid rgba(255, 255, 255, 0.3);
  color: #FFFFFF;
  font-family: var(--font-body, 'Inter', sans-serif);
  font-size: 0.75rem;           /* 12px */
  font-weight: 600;
  letter-spacing: 0.08em;
  text-transform: uppercase;
  text-decoration: none;
  padding: 11px 24px;
  border-radius: var(--radius-pill, 999px);
  transition:
    background 0.25s ease,
    border-color 0.25s ease,
    transform  0.25s cubic-bezier(0.34, 1.56, 0.64, 1),
    box-shadow 0.25s ease;
  white-space: nowrap;
}

.cine-hero__cta-primary svg {
  transition: transform 0.25s cubic-bezier(0.34, 1.56, 0.64, 1);
  flex-shrink: 0;
}

.cine-hero__cta-primary:hover {
  background: rgba(255, 255, 255, 0.25);
  border-color: rgba(255, 255, 255, 0.5);
  transform: translateY(-2px) scale(1.02);
  box-shadow: 0 8px 28px rgba(0, 0, 0, 0.15);
  color: #FFFFFF;
}

.cine-hero__cta-primary:hover svg {
  transform: translateX(4px);
}





/* ── Entry animations ────────────────────────────────────────── */
@keyframes cine-rise {
  to {
    opacity: 1;
    transform: none;
  }
}

/* ── MOBILE overrides ────────────────────────────────────────── */
@media screen and (max-width: 767px) {
  .cine-hero {
    height: 75svh;
    min-height: 520px;
    max-height: 650px;
    align-items: flex-end;
  }

  /* Stronger overlay on mobile for readability */
  .cine-hero__overlay {
    background: linear-gradient(
      to top,
      rgba(20, 10, 10, 0.55) 0%,
      rgba(20, 10, 10, 0.3) 45%,
      rgba(20, 10, 10, 0.05) 100%
    );
  }

  .cine-hero__content {
    align-items: center;
    text-align: center;
    padding: 0 1.5rem 1.5rem;
    transform: translateY(0);
    width: 100%;
  }

  .cine-hero__tagline {
    font-size: 0.55rem;
    letter-spacing: 0.25em;
    margin-bottom: 1rem;
  }

  .cine-hero__heading {
    font-size: clamp(1.4rem, 6.5vw, 2rem);
    max-width: 100%;
    margin-bottom: 1rem;
  }

  .cine-hero__body {
    max-width: 290px;
    font-size: 0.75rem;
    line-height: 1.5;
    margin: 0 auto 1.5rem;
  }

  .cine-hero__ctas {
    flex-direction: column;
    align-items: center;
    width: 100%;
  }

  /* Single full-width primary CTA on mobile */
  .cine-hero__cta-primary {
    width: 90%;
    max-width: 280px;
    justify-content: center;
    padding: 10px 16px;
    font-size: 0.65rem;
  }
}

/* ── Reduced motion ──────────────────────────────────────────── */
@media (prefers-reduced-motion: reduce) {
  .cine-hero__tagline,
  .cine-hero__heading,
  .cine-hero__body,
  .cine-hero__ctas,
    animation: none;
    opacity: 0.6;
  }
}
{%- endstyle -%}

{%- comment -%} ── HTML ──────────────────────────────────────── {%- endcomment -%}
<section
  class="cine-hero"
  id="CineHero-{{ section.id }}"
  aria-label="Hero"
  data-cine-hero
>

  {%- comment -%} ── MEDIA LAYER ─────────────────────────────── {%- endcomment -%}
  <div class="cine-hero__media">

    {%- if section.settings.background_video != blank -%}
      {%- comment -%} Shopify hosted video (uploaded via Files) {%- endcomment -%}
      <video
        id="CineHeroVideo-{{ section.id }}"
        class="cine-hero__video"
        autoplay
        muted
        loop
        playsinline
        preload="metadata"
        aria-hidden="true"
      >
        {%- for source in section.settings.background_video.sources -%}
          <source src="{{ source.url }}" type="{{ source.mime_type }}">
        {%- endfor -%}
        {%- comment -%} Image fallback inside <video> {%- endcomment -%}
        {%- if section.settings.fallback_image != blank -%}
          <img
            src="{{ section.settings.fallback_image | image_url: width: 1600 }}"
            alt=""
            class="cine-hero__img"
            width="1600"
            height="{{ 1600 | divided_by: section.settings.fallback_image.aspect_ratio | round }}"
            fetchpriority="low"
          >
        {%- endif -%}
      </video>

    {%- elsif section.settings.video_url != blank -%}
      {%- comment -%} External / CDN-hosted MP4 {%- endcomment -%}
      <video
        id="CineHeroVideo-{{ section.id }}"
        class="cine-hero__video"
        src="{{ section.settings.video_url }}"
        autoplay
        muted
        loop
        playsinline
        preload="metadata"
        aria-hidden="true"
      ></video>

    {%- elsif section.settings.fallback_image != blank -%}
      {%- comment -%} Static image with slow-zoom animation {%- endcomment -%}
      <img
        src="{{ section.settings.fallback_image | image_url: width: 2000 }}"
        alt="{{ section.settings.fallback_image.alt | escape }}"
        class="cine-hero__img"
        width="2000"
        height="{{ 2000 | divided_by: section.settings.fallback_image.aspect_ratio | round }}"
        fetchpriority="high"
        loading="eager"
      >
    {%- endif -%}

  </div>

  {%- comment -%} ── CINEMATIC OVERLAY ───────────────────────── {%- endcomment -%}
  <div class="cine-hero__overlay" aria-hidden="true"></div>

  {%- comment -%} ── CONTENT BLOCK ───────────────────────────── {%- endcomment -%}
  <div class="cine-hero__content">

    {%- if section.settings.tagline != blank -%}
      <span class="cine-hero__tagline">{{ section.settings.tagline }}</span>
    {%- endif -%}

    <h1 class="cine-hero__heading">
      {%- if section.settings.heading_line1 != blank -%}
        {{ section.settings.heading_line1 }}
        {%- if section.settings.heading_line2 != blank -%}<br>
          <em>{{ section.settings.heading_line2 }}</em>
        {%- endif -%}
      {%- else -%}
        Rituals your skin <em>remembers</em>
      {%- endif -%}
    </h1>

    {%- if section.settings.body_text != blank -%}
      <p class="cine-hero__body">{{ section.settings.body_text }}</p>
    {%- endif -%}

    <div class="cine-hero__ctas">
      {%- if section.settings.cta_primary_label != blank -%}
        <a
          href="{{ section.settings.cta_primary_url | default: routes.all_products_collection_url }}"
          class="cine-hero__cta-primary"
          id="CineHeroCtaPrimary-{{ section.id }}"
        >
          {{ section.settings.cta_primary_label }}
          <svg width="15" height="15" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
            <path d="M5 12h14M12 5l7 7-7 7"/>
          </svg>
        </a>
      {%- endif -%}
    </div>

  </div>




</section>

{%- comment -%} ── JAVASCRIPT ──────────────────────────────── {%- endcomment -%}
<script>
(function () {
  'use strict';

  var heroId   = {{ section.id | json }};
  var heroEl   = document.getElementById('CineHero-' + heroId);
  var videoEl  = document.getElementById('CineHeroVideo-' + heroId);

  if (!heroEl) return;

  /* ── 1. Video Playback Control ───────────────────────────── */
  if (videoEl) {
    /* Ensure autoplay on load (sometimes attributes aren't enough) */
    videoEl.play().catch(function (error) {
      console.warn("Autoplay was prevented by the browser:", error);
    });

    /* Pause video when tab is hidden to save resources */
    document.addEventListener('visibilitychange', function () {
      if (document.hidden) {
        videoEl.pause();
      } else {
        videoEl.play().catch(function () {});
      }
    });



    /* ── 3. Smart Pause on Scroll ────────────────────────────── */
    var ticking = false;
    window.addEventListener('scroll', function () {
      if (ticking) return;
      ticking = true;
      requestAnimationFrame(function () {
        var rect = heroEl.getBoundingClientRect();
        /* If hero is more than 100% off-screen, pause video */
        if (rect.bottom < -100 || rect.top > window.innerHeight + 100) {
          if (!videoEl.paused) videoEl.pause();
        } else {
          if (videoEl.paused && !document.hidden) videoEl.play().catch(function () {});
        }
        ticking = false;
      });
    }, { passive: true });
  }

  /* ── 4. Smooth Cinematic Fade to Next Section ──────────────── */
  var nextSection = heroEl.nextElementSibling;
  if (nextSection) {
    nextSection.style.cssText += 'position:relative;';
    /* Already handled by section z-stacking — no extra work needed */
  }
})();
</script>

