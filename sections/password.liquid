{% comment %}
  Mic & Mac Glow Bars - Storefront Coming Soon / Password Protection Page
  Positions the brand under the new Mark 2 direction: Urban Freshness / Glow Bars.
{% endcomment %}

<div class="password-wrapper">
  <!-- Glowing background elements for a luxury aesthetic -->
  <div class="bg-glow bg-glow-1"></div>
  <div class="bg-glow bg-glow-2"></div>

  <div class="password-card">
    <header class="password-header">
      <!-- Monogram/Logo icon -->
      <img src="{{ 'MicandMac_Monogram.webp' | asset_url }}" alt="Mic & Mac Monogram" class="password-monogram" width="48" height="48" loading="eager">
      
      <div class="brand-badge">URBAN FRESHNESS COMPANY</div>
      <h1 class="brand-title">MIC & MAC</h1>
      <h2 class="brand-subtitle">GLOW BARS</h2>
    </header>

    <div class="password-content">
      <h3 class="teaser-heading">Withstand the Glow</h3>
      <p class="teaser-text">
        A daily defense against urban pollution, transit fatigue, and dullness. Helping urban Indians stay fresh, clean, and confident from home to work.
      </p>
      
      <div class="teaser-divider"></div>
      
      <p class="launch-message">
        We are crafting our digital shelves. Launching soon.
      </p>
    </div>

    <div class="password-footer">
      <details class="password-details">
        <summary class="password-summary">
          <span>Enter Store with Password</span>
          <svg class="icon icon-chevron" width="12" height="12" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
            <polyline points="6 9 12 15 18 9"></polyline>
          </svg>
        </summary>
        
        <div class="password-form-wrapper">
          {% form 'storefront_password', class: 'password-form' %}
            {% if form.errors %}
              <div class="form-errors">
                {{ form.errors | default_errors }}
              </div>
            {% endif %}

            <div class="input-group">
              <input type="password" name="password" id="password-input" placeholder="Password" autocomplete="current-password" required>
              <button type="submit" class="submit-btn" aria-label="Submit password">
                <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
                  <line x1="5" y1="12" x2="19" y2="12"></line>
                  <polyline points="12 5 19 12 12 19"></polyline>
                </svg>
              </button>
            </div>
          {% endform %}
        </div>
      </details>
    </div>
  </div>
</div>

<style>
  /* Password Page Styles - High-end Glassmorphic Dark Mode */
  
  :root {
    --color-pw-bg: #1c120f;
    --color-pw-text: #F3E8E4;
    --color-pw-accent: #D4AF37;
    --color-pw-terracotta: #D18E82;
    --color-pw-card-bg: rgba(46, 31, 26, 0.45);
    --color-pw-card-border: rgba(212, 175, 55, 0.15);
  }

  .password-wrapper {
    position: relative;
    display: flex;
    align-items: center;
    justify-content: center;
    min-height: 100svh;
    background-color: var(--color-pw-bg);
    color: var(--color-pw-text);
    font-family: 'DM Sans', -apple-system, sans-serif;
    padding: 1.5rem;
    overflow: hidden;
  }

  /* Decorative Ambient Glows */
  .bg-glow {
    position: absolute;
    border-radius: 50%;
    filter: blur(100px);
    opacity: 0.15;
    z-index: 1;
    pointer-events: none;
  }

  .bg-glow-1 {
    top: -10%;
    left: -10%;
    width: 60vw;
    height: 60vw;
    background: radial-gradient(circle, #4B2A31 0%, transparent 70%);
  }

  .bg-glow-2 {
    bottom: -15%;
    right: -10%;
    width: 50vw;
    height: 50vw;
    background: radial-gradient(circle, #D18E82 0%, transparent 70%);
  }

  /* Glassmorphism Card Container */
  .password-card {
    position: relative;
    z-index: 5;
    background: var(--color-pw-card-bg);
    backdrop-filter: blur(20px);
    -webkit-backdrop-filter: blur(20px);
    border: 1px solid var(--color-pw-card-border);
    border-radius: 20px;
    padding: 3.5rem 2.5rem;
    width: 100%;
    max-width: 500px;
    box-shadow: 0 30px 60px rgba(0, 0, 0, 0.5);
    text-align: center;
    box-sizing: border-box;
  }

  /* Header Branding */
  .password-monogram {
    display: block;
    margin: 0 auto 1.5rem;
    filter: drop-shadow(0 2px 8px rgba(0, 0, 0, 0.3));
    height: 48px;
    width: auto;
  }

  .brand-badge {
    display: inline-block;
    font-size: 0.7rem;
    font-weight: 600;
    letter-spacing: 0.25em;
    color: var(--color-pw-accent);
    border: 1px solid rgba(212, 175, 55, 0.3);
    padding: 0.4rem 0.9rem;
    border-radius: 50px;
    margin-bottom: 1.25rem;
    text-transform: uppercase;
    background: rgba(212, 175, 55, 0.05);
  }

  .brand-title {
    font-family: 'Cormorant Garamond', Georgia, serif;
    font-size: 2.5rem;
    font-weight: 300;
    letter-spacing: 0.1em;
    margin: 0 0 0.25rem 0;
    color: var(--color-pw-text);
  }

  .brand-subtitle {
    font-size: 0.85rem;
    font-weight: 500;
    letter-spacing: 0.4em;
    margin: 0 0 2.5rem 0;
    color: var(--color-pw-terracotta);
    text-transform: uppercase;
    padding-left: 0.4em; /* Offset for letter-spacing alignment */
  }

  /* Teaser Content */
  .teaser-heading {
    font-family: 'Cormorant Garamond', Georgia, serif;
    font-size: 1.6rem;
    font-weight: 400;
    font-style: italic;
    color: var(--color-pw-text);
    margin-bottom: 1rem;
  }

  .teaser-text {
    font-size: 0.95rem;
    line-height: 1.6;
    color: rgba(243, 232, 228, 0.8);
    margin-bottom: 2rem;
    text-wrap: pretty;
  }

  .teaser-divider {
    height: 1px;
    width: 60px;
    background: linear-gradient(90deg, transparent, var(--color-pw-accent), transparent);
    margin: 0 auto 2rem;
  }

  .launch-message {
    font-size: 0.85rem;
    font-weight: 500;
    letter-spacing: 0.05em;
    color: var(--color-pw-accent);
    margin-bottom: 2.5rem;
  }

  /* Accordion Login Details */
  .password-details {
    border-top: 1px solid rgba(243, 232, 228, 0.1);
    padding-top: 1.5rem;
  }

  .password-summary {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    gap: 0.5rem;
    font-size: 0.85rem;
    font-weight: 500;
    color: rgba(243, 232, 228, 0.7);
    cursor: pointer;
    list-style: none;
    transition: color 0.3s ease;
    user-select: none;
  }

  .password-summary::-webkit-details-marker {
    display: none;
  }

  .password-summary:hover {
    color: var(--color-pw-accent);
  }

  .password-summary .icon-chevron {
    transition: transform 0.3s ease;
  }

  .password-details[open] .password-summary .icon-chevron {
    transform: rotate(180deg);
  }

  .password-form-wrapper {
    margin-top: 1.25rem;
    animation: fadeIn 0.4s cubic-bezier(0.16, 1, 0.3, 1);
  }

  /* Form Elements */
  .password-form {
    display: block;
  }

  .form-errors {
    font-size: 0.8rem;
    color: #e74c3c;
    margin-bottom: 1rem;
    text-align: left;
    background: rgba(231, 76, 60, 0.1);
    padding: 0.75rem 1rem;
    border-radius: 8px;
    border-left: 3px solid #e74c3c;
  }

  .input-group {
    position: relative;
    display: flex;
    align-items: center;
    max-width: 320px;
    margin: 0 auto;
  }

  .input-group input[type="password"] {
    width: 100%;
    background: rgba(28, 18, 15, 0.6);
    border: 1px solid rgba(243, 232, 228, 0.2);
    border-radius: 50px;
    color: var(--color-pw-text);
    padding: 0.8rem 3.5rem 0.8rem 1.25rem;
    font-size: 0.95rem;
    transition: all 0.3s ease;
    outline: none;
  }

  .input-group input[type="password"]:focus {
    border-color: var(--color-pw-accent);
    box-shadow: 0 0 10px rgba(212, 175, 55, 0.15);
    background: rgba(28, 18, 15, 0.85);
  }

  .submit-btn {
    position: absolute;
    right: 5px;
    background: var(--color-pw-accent);
    border: none;
    border-radius: 50%;
    width: 36px;
    height: 36px;
    display: flex;
    align-items: center;
    justify-content: center;
    color: #1c120f;
    cursor: pointer;
    transition: all 0.3s ease;
  }

  .submit-btn:hover {
    background: var(--color-pw-text);
    transform: scale(1.05);
  }

  .submit-btn svg {
    transition: transform 0.3s ease;
  }

  .submit-btn:hover svg {
    transform: translateX(2px);
  }

  /* Animations */
  @keyframes fadeIn {
    from {
      opacity: 0;
      transform: translateY(-8px);
    }
    to {
      opacity: 1;
      transform: translateY(0);
    }
  }

  /* Responsive Adjustments */
  @media (max-width: 480px) {
    .password-card {
      padding: 2.5rem 1.5rem;
    }
    
    .brand-title {
      font-size: 2rem;
    }

    .brand-subtitle {
      font-size: 0.75rem;
      margin-bottom: 2rem;
    }

    .teaser-heading {
      font-size: 1.4rem;
    }
  }
</style>

{% schema %}
{
  "name": "Password Page Teaser",
  "settings": []
}
{% endschema %}
