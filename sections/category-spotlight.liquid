{% comment %}
  Section: Category Spotlight
  Editorial two-column layout for a product category.
  Left: full-bleed glowing image column
  Right: badge, eyebrow, headline, body copy, star rating, key benefits, CTA button
  Supports image-left and image-right via `image_position` setting.
{% endcomment %}

{%- style -%}

/* ── Shell ─────────────────────────────────────────── */
.cat-spot-{{ section.id }} {
  background: {{ section.settings.bg_color | default: '#FDFAF6' }};
  padding-top: {{ section.settings.padding_top | default: 0 }}px;
  padding-bottom: {{ section.settings.padding_bottom | default: 0 }}px;
  overflow: hidden;
}

/* ── Two-column grid ───────────────────────────────── */
.cat-spot-{{ section.id }} .cs__inner {
  display: grid;
  grid-template-columns: 55fr 45fr;
  min-height: {{ section.settings.min_height | default: 580 }}px;
  align-items: stretch;
}

@media screen and (max-width: 899px) {
  .cat-spot-{{ section.id }} .cs__inner {
    grid-template-columns: 1fr;
    min-height: auto;
  }
}

/* ── Image column ──────────────────────────────────── */
.cat-spot-{{ section.id }} .cs__img-col {
  position: relative;
  overflow: hidden;
  background: {{ section.settings.img_bg_color | default: '#EDD9B8' }};
  {% if section.settings.image_position == 'right' %}order: 2;{% else %}order: 1;{% endif %}
}

@media screen and (max-width: 899px) {
  .cat-spot-{{ section.id }} .cs__img-col {
    order: 0 !important;
    aspect-ratio: 4/3;
  }
  .cat-spot-{{ section.id }} .cs__content-col {
    order: 1 !important;
  }
}

/* Removed glow overlay per request */

.cat-spot-{{ section.id }} .cs__img-col img {
  width: 100%;
  height: 100%;
  object-fit: cover;
  object-position: center;
  display: block;
  transition: transform 0.9s cubic-bezier(0.25, 0.46, 0.45, 0.94);
  position: relative;
  z-index: 1;
}

.cat-spot-{{ section.id }}:hover .cs__img-col img {
  transform: scale(1.04);
}

/* ── Content column ────────────────────────────────── */
.cat-spot-{{ section.id }} .cs__content-col {
  display: flex;
  flex-direction: column;
  justify-content: center;
  padding: 4rem 3.5rem;
  {% if section.settings.image_position == 'right' %}order: 1;{% else %}order: 2;{% endif %}
}

@media screen and (max-width: 1099px) {
  .cat-spot-{{ section.id }} .cs__content-col {
    padding: 3rem 2.5rem;
  }
}

@media screen and (max-width: 749px) {
  .cat-spot-{{ section.id }} .cs__content-col {
    padding: 2.25rem 1.5rem;
  }
}

/* ── Eyebrow row (badge + category label) ──────────── */
.cat-spot-{{ section.id }} .cs__eyebrow-row {
  display: flex;
  align-items: center;
  gap: 10px;
  margin-bottom: 1.1rem;
}

.cat-spot-{{ section.id }} .cs__badge {
  display: inline-block;
  background: #4A1040;
  color: #D4A96A;
  font-size: 8px;
  font-weight: 700;
  letter-spacing: 0.14em;
  text-transform: uppercase;
  padding: 3px 9px;
  border-radius: 2px;
  flex-shrink: 0;
}

.cat-spot-{{ section.id }} .cs__eyebrow {
  font-family: var(--font-body);
  font-size: 10px;
  font-weight: 600;
  letter-spacing: 0.22em;
  text-transform: uppercase;
  color: #B8924A;
}

/* ── Category label ────────────────────────────────── */
.cat-spot-{{ section.id }} .cs__category-label {
  font-family: var(--font-body);
  font-size: 9px;
  font-weight: 700;
  letter-spacing: 0.28em;
  text-transform: uppercase;
  color: {{ section.settings.accent_color | default: '#B8924A' }};
  margin-bottom: 0.6rem;
}

/* ── Headline ──────────────────────────────────────── */
.cat-spot-{{ section.id }} .cs__heading {
  font-family: var(--font-display, 'Cormorant Garamond', Georgia, serif);
  font-size: clamp(1.85rem, 3vw, 2.9rem);
  font-weight: 300;
  line-height: 1.12;
  color: #2A1520;
  margin-bottom: 0.6rem;
  letter-spacing: -0.01em;
}

.cat-spot-{{ section.id }} .cs__heading em {
  font-style: italic;
  color: {{ section.settings.accent_color | default: '#B8924A' }};
}

/* ── Star rating ───────────────────────────────────── */
.cat-spot-{{ section.id }} .cs__stars-row {
  display: flex;
  align-items: center;
  gap: 8px;
  margin-bottom: 1.25rem;
}

.cat-spot-{{ section.id }} .cs__stars {
  color: #C9A84C;
  font-size: 1rem;
  letter-spacing: 2px;
}

.cat-spot-{{ section.id }} .cs__rating-label {
  font-family: var(--font-body);
  font-size: 0.72rem;
  color: #9A8880;
  font-weight: 400;
}

/* ── Body copy ─────────────────────────────────────── */
.cat-spot-{{ section.id }} .cs__body {
  font-family: var(--font-body);
  font-size: 0.9375rem;
  line-height: 1.75;
  color: #5C3D2E;
  margin-bottom: 1.5rem;
  max-width: 400px;
}

/* ── Key benefits list ─────────────────────────────── */
.cat-spot-{{ section.id }} .cs__benefits {
  list-style: none;
  padding: 0;
  margin: 0 0 2rem 0;
  display: flex;
  flex-direction: column;
  gap: 0.55rem;
}

.cat-spot-{{ section.id }} .cs__benefit-item {
  display: flex;
  align-items: flex-start;
  gap: 9px;
  font-family: var(--font-body);
  font-size: 0.82rem;
  color: #5C3D2E;
  line-height: 1.5;
}

.cat-spot-{{ section.id }} .cs__benefit-dot {
  width: 5px;
  height: 5px;
  border-radius: 50%;
  background: {{ section.settings.accent_color | default: '#B8924A' }};
  flex-shrink: 0;
  margin-top: 6px;
}

/* ── CTA ───────────────────────────────────────────── */
.cat-spot-{{ section.id }} .cs__actions {
  display: flex;
  flex-wrap: wrap;
  gap: 0.75rem;
  max-width: 340px;
}

.cat-spot-{{ section.id }} .cs__btn-primary {
  display: inline-flex;
  align-items: center;
  gap: 8px;
  background: #4A1040;
  color: #F5ECD7;
  border: none;
  padding: 14px 28px;
  font-family: var(--font-body);
  font-size: 11px;
  font-weight: 600;
  letter-spacing: 0.1em;
  text-transform: uppercase;
  border-radius: 2px;
  text-decoration: none;
  cursor: pointer;
  transition: background 0.22s ease, transform 0.22s ease, box-shadow 0.22s ease;
  white-space: nowrap;
}

.cat-spot-{{ section.id }} .cs__btn-primary:hover {
  background: #2A1520;
  transform: translateY(-1px);
  box-shadow: 0 6px 18px rgba(74, 16, 64, 0.25);
}

.cat-spot-{{ section.id }} .cs__btn-secondary {
  display: inline-flex;
  align-items: center;
  gap: 6px;
  background: transparent;
  color: #4A1040;
  border: 1px solid #4A1040;
  padding: 13px 24px;
  font-family: var(--font-body);
  font-size: 11px;
  font-weight: 600;
  letter-spacing: 0.1em;
  text-transform: uppercase;
  border-radius: 2px;
  text-decoration: none;
  transition: background 0.22s ease, color 0.22s ease;
  white-space: nowrap;
}

.cat-spot-{{ section.id }} .cs__btn-secondary:hover {
  background: #4A1040;
  color: #F5ECD7;
}

{%- endstyle -%}


<section
  class="cat-spot-{{ section.id }}"
  id="CategorySpotlight-{{ section.id }}"
>
  <div class="cs__inner">

    {%- comment -%} ── IMAGE COLUMN ──────────────────────── {%- endcomment -%}
    <div class="cs__img-col">
      {%- if section.settings.image != blank -%}
        <img
          src="{{ section.settings.image | image_url: width: 1200 }}"
          alt="{{ section.settings.image.alt | escape | default: section.settings.heading }}"
          width="1200"
          height="{{ 1200 | divided_by: section.settings.image.aspect_ratio | round }}"
          loading="lazy"
        >
      {%- else -%}
        {{ 'product-1' | placeholder_svg_tag: 'cs__placeholder-svg' }}
      {%- endif -%}
    </div>

    {%- comment -%} ── CONTENT COLUMN ──────────────────────── {%- endcomment -%}
    <div class="cs__content-col">

      {%- comment -%} Eyebrow row: badge + category tag {%- endcomment -%}
      <div class="cs__eyebrow-row">
        {%- if section.settings.badge_label != blank -%}
          <span class="cs__badge">{{ section.settings.badge_label }}</span>
        {%- endif -%}
        {%- if section.settings.eyebrow != blank -%}
          <span class="cs__eyebrow">{{ section.settings.eyebrow }}</span>
        {%- endif -%}
      </div>

      {%- comment -%} Heading {%- endcomment -%}
      {%- if section.settings.heading != blank -%}
        <h2 class="cs__heading">{{ section.settings.heading }}</h2>
      {%- endif -%}

      {%- comment -%} Stars {%- endcomment -%}
      {%- if section.settings.show_stars -%}
        <div class="cs__stars-row">
          <span class="cs__stars" aria-label="{{ section.settings.rating_value }} out of 5 stars">★★★★★</span>
          <span class="cs__rating-label">{{ section.settings.rating_value | default: '4.9' }} · {{ section.settings.review_count | default: '200+' }} reviews</span>
        </div>
      {%- endif -%}

      {%- comment -%} Body copy {%- endcomment -%}
      {%- if section.settings.body_text != blank -%}
        <p class="cs__body">{{ section.settings.body_text }}</p>
      {%- endif -%}

      {%- comment -%} Key Benefits {%- endcomment -%}
      {%- assign benefit_1 = section.settings.benefit_1 -%}
      {%- assign benefit_2 = section.settings.benefit_2 -%}
      {%- assign benefit_3 = section.settings.benefit_3 -%}
      {%- assign benefit_4 = section.settings.benefit_4 -%}
      {%- if benefit_1 != blank or benefit_2 != blank or benefit_3 != blank -%}
        <ul class="cs__benefits" aria-label="Key benefits">
          {%- if benefit_1 != blank -%}
            <li class="cs__benefit-item"><span class="cs__benefit-dot" aria-hidden="true"></span>{{ benefit_1 }}</li>
          {%- endif -%}
          {%- if benefit_2 != blank -%}
            <li class="cs__benefit-item"><span class="cs__benefit-dot" aria-hidden="true"></span>{{ benefit_2 }}</li>
          {%- endif -%}
          {%- if benefit_3 != blank -%}
            <li class="cs__benefit-item"><span class="cs__benefit-dot" aria-hidden="true"></span>{{ benefit_3 }}</li>
          {%- endif -%}
          {%- if benefit_4 != blank -%}
            <li class="cs__benefit-item"><span class="cs__benefit-dot" aria-hidden="true"></span>{{ benefit_4 }}</li>
          {%- endif -%}
        </ul>
      {%- endif -%}

      {%- comment -%} CTA Buttons {%- endcomment -%}
      <div class="cs__actions">
        {%- if section.settings.cta_primary_label != blank -%}
          <a
            href="{{ section.settings.cta_primary_url | default: '/collections/all' }}"
            class="cs__btn-primary"
            id="CatSpotCtaPrimary-{{ section.id }}"
          >
            {{ section.settings.cta_primary_label }}
            <svg width="13" height="13" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
              <path d="M5 12h14M12 5l7 7-7 7"/>
            </svg>
          </a>
        {%- endif -%}
        {%- if section.settings.cta_secondary_label != blank -%}
          <a
            href="{{ section.settings.cta_secondary_url | default: '/collections/all' }}"
            class="cs__btn-secondary"
            id="CatSpotCtaSecondary-{{ section.id }}"
          >
            {{ section.settings.cta_secondary_label }}
          </a>
        {%- endif -%}
      </div>

    </div>
  </div>
</section>


{% schema %}
{
  "name": "Category Spotlight",
  "settings": [
    {
      "type": "header",
      "content": "🖼 Image"
    },
    {
      "type": "image_picker",
      "id": "image",
      "label": "Category image"
    },
    {
      "type": "header",
      "content": "✍️ Copy"
    },
    {
      "type": "text",
      "id": "badge_label",
      "label": "Badge (e.g. Bestseller / New)",
      "default": "Bestseller"
    },
    {
      "type": "text",
      "id": "eyebrow",
      "label": "Eyebrow tag (category / key attribute)",
      "default": "Cold Pressed · Deep Hydration"
    },
    {
      "type": "text",
      "id": "heading",
      "label": "Section heading",
      "default": "Handcrafted Soaps"
    },
    {
      "type": "checkbox",
      "id": "show_stars",
      "label": "Show star rating",
      "default": true
    },
    {
      "type": "text",
      "id": "rating_value",
      "label": "Rating (e.g. 4.9)",
      "default": "4.9"
    },
    {
      "type": "text",
      "id": "review_count",
      "label": "Review count label (e.g. 200+)",
      "default": "200+"
    },
    {
      "type": "textarea",
      "id": "body_text",
      "label": "Body copy"
    },
    {
      "type": "header",
      "content": "✅ Key Benefits"
    },
    {
      "type": "text",
      "id": "benefit_1",
      "label": "Benefit 1"
    },
    {
      "type": "text",
      "id": "benefit_2",
      "label": "Benefit 2"
    },
    {
      "type": "text",
      "id": "benefit_3",
      "label": "Benefit 3"
    },
    {
      "type": "text",
      "id": "benefit_4",
      "label": "Benefit 4"
    },
    {
      "type": "header",
      "content": "🔗 CTA Buttons"
    },
    {
      "type": "text",
      "id": "cta_primary_label",
      "label": "Primary button label",
      "default": "Shop Soaps"
    },
    {
      "type": "url",
      "id": "cta_primary_url",
      "label": "Primary button link"
    },
    {
      "type": "text",
      "id": "cta_secondary_label",
      "label": "Secondary button label (optional)"
    },
    {
      "type": "url",
      "id": "cta_secondary_url",
      "label": "Secondary button link"
    },
    {
      "type": "header",
      "content": "🎨 Layout & Colours"
    },
    {
      "type": "select",
      "id": "image_position",
      "label": "Image side",
      "options": [
        { "value": "left", "label": "Left (image · content)" },
        { "value": "right", "label": "Right (content · image)" }
      ],
      "default": "left"
    },
    {
      "type": "color",
      "id": "bg_color",
      "label": "Section background",
      "default": "#FDFAF6"
    },
    {
      "type": "color",
      "id": "img_bg_color",
      "label": "Image column background",
      "default": "#EDD9B8"
    },
    {
      "type": "color",
      "id": "accent_color",
      "label": "Accent colour (dots, eyebrow, heading em)",
      "default": "#B8924A"
    },
    {
      "type": "color",
      "id": "glow_color",
      "label": "Image glow overlay colour",
      "default": "#D4AF37"
    },
    {
      "type": "range",
      "id": "min_height",
      "min": 400,
      "max": 900,
      "step": 20,
      "unit": "px",
      "label": "Minimum section height (desktop)",
      "default": 580
    },
    {
      "type": "header",
      "content": "📐 Spacing"
    },
    {
      "type": "range",
      "id": "padding_top",
      "min": 0,
      "max": 100,
      "step": 4,
      "unit": "px",
      "label": "Padding top",
      "default": 0
    },
    {
      "type": "range",
      "id": "padding_bottom",
      "min": 0,
      "max": 100,
      "step": 4,
      "unit": "px",
      "label": "Padding bottom",
      "default": 0
    }
  ],
  "presets": [
    {
      "name": "Category Spotlight",
      "settings": {
        "badge_label": "Bestseller",
        "eyebrow": "Cold Pressed · Deep Hydration",
        "heading": "Handcrafted Soaps",
        "show_stars": true,
        "rating_value": "4.9",
        "review_count": "200+",
        "image_position": "left",
        "bg_color": "#FDFAF6",
        "img_bg_color": "#EDD9B8",
        "accent_color": "#B8924A"
      }
    }
  ]
}
{% endschema %}
