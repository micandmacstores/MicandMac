{% comment %}
  Section: page-my-account
  Custom account dashboard - works with Shopify New Customer Accounts.
  Upgraded UI: High contrast, Read/Edit modes, mobile top-tabs.
  URL: /pages/my-account
{% endcomment %}

{% if customer %}

{%- comment -%} ── LOGGED-IN STATE ── {%- endcomment -%}

<div class="account-page" id="AccountPage">
  <div class="container container--narrow">
    <div class="account-page__layout">

      <!-- ══ SIDEBAR ════════════════════════════════════════════════════ -->
      <aside class="account-page__sidebar">
        <nav class="account-nav" aria-label="Account navigation">

          <div class="account-nav__profile">
            <div class="account-nav__avatar">{{ customer.first_name | slice: 0 | upcase }}{{ customer.last_name | slice: 0 | upcase | default: '' }}</div>
            <div class="account-nav__user">
              <p class="account-nav__greeting">{{ customer.first_name }} {{ customer.last_name | default: '' }}</p>
              <p class="account-nav__email">{{ customer.email }}</p>
            </div>
          </div>
          <hr class="account-nav__rule">

          <ul class="account-nav__list">
            <li>
              <button class="account-nav__link is-active" data-tab="orders" aria-selected="true" type="button">
                Orders
              </button>
            </li>
            <li>
              <button class="account-nav__link" data-tab="addresses" aria-selected="false" type="button">
                Addresses
              </button>
            </li>
            <li>
              <button class="account-nav__link" data-tab="details" aria-selected="false" type="button">
                Account Details
              </button>
            </li>
          </ul>

          <hr class="account-nav__rule desktop-only">

          <div class="account-nav__bottom desktop-only">
            <a href="{{ routes.account_logout_url }}" class="account-nav__link account-nav__link--logout">
              Log out
            </a>
          </div>

        </nav>
      </aside>

      <!-- ══ MAIN CONTENT ═══════════════════════════════════════════════ -->
      <main class="account-page__main">

        <!-- ─── PANEL 1 - ORDERS ──────────────────────────────────────── -->
        <div class="acct-panel is-active" id="panel-orders" role="tabpanel" aria-label="Orders">

          <div class="acct-header">
            <h1 class="acct-header__title">Your Orders</h1>
            {%- if customer.orders.size > 0 -%}
              <p class="acct-header__subtitle">
                {{ customer.orders.size }} order{% if customer.orders.size != 1 %}s{% endif %} placed
              </p>
            {%- endif -%}
          </div>

          {%- if customer.orders.size > 0 -%}
            <div class="order-list">
              {%- for order in customer.orders -%}
                <div class="order-card">
                  <div class="order-card__header">
                    <div>
                      <p class="order-card__id">Order #{{ order.name }}</p>
                      <p class="order-card__date">{{ order.created_at | date: '%b %d, %Y' }}</p>
                    </div>
                    <div class="order-card__price-area">
                      <p class="order-card__price">{{ order.total_price | money }}</p>
                    </div>
                  </div>

                  <div class="order-card__body">
                    {%- assign f_status = order.fulfillment_status | default: 'unfulfilled' -%}
                    {%- case f_status -%}
                      {%- when 'fulfilled' -%}
                        {%- assign status_label = 'Delivered' -%}
                        {%- assign status_mod   = 'order-card__status--fulfilled' -%}
                      {%- when 'in_progress' -%}
                        {%- assign status_label = 'In Transit' -%}
                        {%- assign status_mod   = 'order-card__status--shipping' -%}
                      {%- when 'partial' -%}
                        {%- assign status_label = 'Partially Shipped' -%}
                        {%- assign status_mod   = 'order-card__status--shipping' -%}
                      {%- else -%}
                        {%- assign status_label = 'Order Confirmed' -%}
                        {%- assign status_mod   = 'order-card__status--confirmed' -%}
                    {%- endcase -%}
                    <span class="order-card__status {{ status_mod }}">
                      {{ status_label }}
                    </span>
                    <span class="order-card__items">{{ order.line_items_count }} item{% if order.line_items_count != 1 %}s{% endif %}</span>
                  </div>
                  
                  <div class="order-card__footer">
                    <a href="{{ order.customer_url }}" class="order-card__cta">View details</a>
                  </div>
                </div>
              {%- endfor -%}
            </div>

          {%- else -%}
            <div class="acct-empty">
              <h2 class="acct-empty__title">No orders yet</h2>
              <p class="acct-empty__text">When you place an order, it'll appear here.</p>
              <a href="{{ routes.all_products_collection_url }}" class="btn-outline">Shop All</a>
            </div>
          {%- endif -%}

        </div>


        <!-- ─── PANEL 2 - ADDRESSES ───────────────────────────────────── -->
        <div class="acct-panel" id="panel-addresses" role="tabpanel" aria-label="Addresses" hidden>

          <div class="acct-header acct-header--split">
            <div>
              <h1 class="acct-header__title">Saved Addresses</h1>
              {%- if customer.addresses.size > 0 -%}
                <p class="acct-header__subtitle">
                  {{ customer.addresses.size }} address{% if customer.addresses.size != 1 %}es{% endif %} saved
                </p>
              {%- endif -%}
            </div>
            <button type="button" class="btn-outline btn-outline--small" id="ToggleNewAddressBtn">
              Add Address
            </button>
          </div>

          {%- if customer.addresses.size > 0 -%}
            <div class="address-grid">
              {%- for address in customer.addresses -%}
                {%- assign is_default = false -%}
                {%- if address.id == customer.default_address.id -%}
                  {%- assign is_default = true -%}
                {%- endif -%}

                <div class="address-card{% if is_default %} address-card--default{% endif %}">
                  <div class="address-card__header">
                    <p class="address-card__label">{{ address.first_name }} {{ address.last_name }}</p>
                    {%- if is_default -%}
                      <span class="address-card__badge">Default</span>
                    {%- endif -%}
                  </div>

                  <address>
                    {%- if address.address1 != blank -%}{{ address.address1 }}<br>{%- endif -%}
                    {%- if address.address2 != blank -%}{{ address.address2 }}<br>{%- endif -%}
                    {%- if address.city != blank -%}{{ address.city }}{%- endif -%}
                    {%- if address.province != blank -%}, {{ address.province }}{%- endif -%}
                    {%- if address.zip != blank -%} {{ address.zip }}{%- endif -%}
                    <br>{{ address.country }}
                    {%- if address.phone != blank -%}<br>{{ address.phone }}{%- endif -%}
                  </address>

                  <div class="address-card__actions">
                    {%- unless is_default -%}
                      {%- form 'customer_address', address -%}
                        <input type="hidden" name="_method" value="put">
                        <input type="hidden" name="address[default]" value="true">
                        <button type="submit" class="btn-text">Make Default</button>
                      {%- endform -%}
                    {%- endunless -%}

                    {%- form 'customer_address', address -%}
                      <input type="hidden" name="_method" value="delete">
                      <button type="button" class="btn-text btn-text--danger js-delete-address-btn">Delete</button>
                    {%- endform -%}
                  </div>
                </div>
              {%- endfor -%}
            </div>
          {%- else -%}
            <div class="acct-empty">
              <h2 class="acct-empty__title">No addresses saved</h2>
              <p class="acct-empty__text" style="margin-bottom: 1.5rem;">Add a shipping address to speed up checkout.</p>
              <button type="button" class="btn-outline" id="EmptyAddAddressBtn">Add Address</button>
            </div>
          {%- endif -%}

          <!-- Add New Address Form -->
          <div class="acct-card address-form-wrap" id="NewAddressFormWrap" style="{% unless form.errors %}display: none;{% endunless %} margin-top: 2rem;">
            <h2 class="acct-card__title">Add New Address</h2>

            {%- form 'customer_address', customer.new_address, id: 'NewAddressForm' -%}
              {%- if form.errors -%}
                <div class="form-errors">{{ form.errors | default_errors }}</div>
              {%- endif -%}

              <div class="form-row">
                <div class="form-group">
                  <label for="NewFirstName" class="form-label">First name</label>
                  <input type="text" id="NewFirstName" name="address[first_name]"
                    value="{{ form.first_name | escape }}" class="form-input" autocomplete="given-name">
                </div>
                <div class="form-group">
                  <label for="NewLastName" class="form-label">Last name</label>
                  <input type="text" id="NewLastName" name="address[last_name]"
                    value="{{ form.last_name | escape }}" class="form-input" autocomplete="family-name">
                </div>
              </div>

              <div class="form-group">
                <label for="NewAddress1" class="form-label">Address</label>
                <input type="text" id="NewAddress1" name="address[address1]"
                  value="{{ form.address1 | escape }}" class="form-input" autocomplete="address-line1">
              </div>

              <div class="form-group">
                <label for="NewAddress2" class="form-label">
                  Apartment, suite, etc. <span class="form-label-optional">(optional)</span>
                </label>
                <input type="text" id="NewAddress2" name="address[address2]"
                  value="{{ form.address2 | escape }}" class="form-input" autocomplete="address-line2">
              </div>

              <div class="form-row">
                <div class="form-group">
                  <label for="NewCity" class="form-label">City</label>
                  <input type="text" id="NewCity" name="address[city]"
                    value="{{ form.city | escape }}" class="form-input" autocomplete="address-level2">
                </div>
                <div class="form-group">
                  <label for="NewZip" class="form-label">ZIP / Postcode</label>
                  <input type="text" id="NewZip" name="address[zip]"
                    value="{{ form.zip | escape }}" class="form-input" autocomplete="postal-code">
                </div>
              </div>

              <div class="form-group">
                <label for="NewCountry" class="form-label">Country</label>
                <div class="custom-select-wrapper">
                  <select id="NewCountry" name="address[country]" class="form-input custom-select-hidden" style="display: none;">
                    {{ all_country_option_tags }}
                  </select>
                  <button type="button" class="custom-select-trigger" id="CountrySelectTrigger">
                    <span class="custom-select-trigger-text">---</span>
                    <svg class="custom-select-arrow" xmlns="http://www.w3.org/2000/svg" width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
                      <polyline points="6 9 12 15 18 9"></polyline>
                    </svg>
                  </button>
                  <div class="custom-select-options-container" id="CountrySelectOptions">
                    <ul class="custom-select-options">
                      <!-- Dynamically populated via JS -->
                    </ul>
                  </div>
                </div>
              </div>

              <div class="form-group">
                <label for="NewPhone" class="form-label">
                  Phone <span class="form-label-optional">(optional)</span>
                </label>
                <input type="tel" id="NewPhone" name="address[phone]"
                  value="{{ form.phone | escape }}" class="form-input" placeholder="+91 XXXXXXXXXX" autocomplete="tel">
              </div>

              <div class="form-group form-group--checkbox">
                <input type="checkbox" id="NewDefault" name="address[default]" value="true" class="form-checkbox">
                <label for="NewDefault" class="form-label-checkbox">
                  Set as default address
                </label>
              </div>

              <div style="display: flex; gap: 1rem; align-items: center; margin-top: 1.5rem;">
                <button type="submit" class="btn-primary" style="margin-top: 0;">Save address</button>
                <button type="button" class="btn-outline" id="CancelNewAddressBtn">Cancel</button>
              </div>
            {%- endform -%}
          </div>

        </div>

        <!-- ─── PANEL 4 - ACCOUNT DETAILS ─────────────────────────────── -->
        <div class="acct-panel" id="panel-details" role="tabpanel" aria-label="Account details" hidden>

          <div class="acct-header acct-header--split">
            <div>
              <h1 class="acct-header__title">Profile Details</h1>
              <p class="acct-header__subtitle">Manage your personal information</p>
            </div>
            <button type="button" class="btn-outline btn-outline--small" id="ToggleEditDetailsBtn">
              Edit
            </button>
          </div>

          <!-- READ MODE (Default) -->
          <div class="acct-card" id="DetailsReadMode">
            <h2 class="acct-card__subtitle">BASIC INFORMATION</h2>
            <div class="acct-details-grid">
              <div class="acct-detail-item">
                <span class="acct-detail-label">First Name</span>
                <span class="acct-detail-value">{{ customer.first_name | default: '-' }}</span>
              </div>
              <div class="acct-detail-item">
                <span class="acct-detail-label">Last Name</span>
                <span class="acct-detail-value">{{ customer.last_name | default: '-' }}</span>
              </div>
              <div class="acct-detail-item">
                <span class="acct-detail-label">Email Address</span>
                <span class="acct-detail-value">{{ customer.email }}</span>
              </div>
              <div class="acct-detail-item">
                <span class="acct-detail-label">Phone Number</span>
                <span class="acct-detail-value">{{ customer.phone | default: '-' }}</span>
              </div>
            </div>
          </div>

          <!-- EDIT MODE (Hidden by default) -->
          <div class="acct-card" id="DetailsEditMode" hidden>
            <h2 class="acct-card__subtitle">EDIT INFORMATION</h2>
            {%- form 'customer' -%}
              {%- if form.errors -%}
                <div class="form-errors">{{ form.errors | default_errors }}</div>
              {%- endif -%}

              <div class="form-row">
                <div class="form-group">
                  <label for="CustFirstName" class="form-label">First name</label>
                  <input type="text" id="CustFirstName" name="customer[first_name]"
                    value="{{ customer.first_name | escape }}" class="form-input" autocomplete="given-name">
                </div>
                <div class="form-group">
                  <label for="CustLastName" class="form-label">Last name</label>
                  <input type="text" id="CustLastName" name="customer[last_name]"
                    value="{{ customer.last_name | escape }}" class="form-input" autocomplete="family-name">
                </div>
              </div>

              <div class="form-row">
                <div class="form-group">
                  <label for="CustEmail" class="form-label">Email</label>
                  <input type="email" id="CustEmail" value="{{ customer.email | escape }}"
                    class="form-input" readonly title="Email cannot be changed here">
                </div>
                <div class="form-group">
                  <label for="CustPhone" class="form-label">
                    Phone <span class="form-label-optional">(optional)</span>
                  </label>
                  <input type="tel" id="CustPhone" name="customer[phone]"
                    value="{{ customer.phone | escape }}" class="form-input" placeholder="+91 XXXXXXXXXX" autocomplete="tel">
                </div>
              </div>

              <div class="form-actions">
                <button type="submit" class="btn-primary" id="DetailsSaveBtn">Save Changes</button>
                <button type="button" class="btn-text" id="CancelEditDetailsBtn">Cancel</button>
              </div>
            {%- endform -%}
          </div>

          <div class="acct-security-block">
            <p>Password or security settings?</p>
            <a href="/account" class="btn-text">Manage setting natively &rarr;</a>
          </div>

        </div>

      </main>
    </div>
  </div>
</div>

{% else %}

{%- comment -%} ── GUEST STATE - not logged in ── {%- endcomment -%}

<div class="account-page">
  <div class="container container--narrow">
    <div class="acct-guest acct-card">
      <h1 class="acct-guest__title">Sign in to your account</h1>
      <p class="acct-guest__text">Access your orders, saved addresses, and wishlist.</p>
      <a href="{{ routes.account_login_url }}" class="btn-primary" style="display:inline-block;text-decoration:none;">
        Sign in
      </a>
      <p class="acct-guest__alt">
        Don't have an account?
        <a href="{{ routes.account_register_url }}">Create one →</a>
      </p>
    </div>
  </div>
</div>

{% endif %}

<!-- Custom Confirmation Modal -->
<div class="acct-modal-overlay" id="ConfirmDeleteModal" hidden>
  <div class="acct-modal">
    <h3 class="acct-modal__title">Delete Address</h3>
    <p class="acct-modal__text">Are you sure you want to delete this address? This action cannot be undone.</p>
    <div class="acct-modal__actions">
      <button type="button" class="btn-outline" id="CancelDeleteBtn">Cancel</button>
      <button type="button" class="btn-primary" style="background:#8B2020;" id="ConfirmDeleteBtn">Delete</button>
    </div>
  </div>
</div>

<!-- Toast -->
<div class="acct-toast" id="AcctToast" role="status" aria-live="polite"></div>

<script>
(function () {
  'use strict';

  const navBtns = document.querySelectorAll('[data-tab]');
  const panels  = document.querySelectorAll('.acct-panel');
  const toast   = document.getElementById('AcctToast');

  /* ── Tab switching ──────────────────────────────────────── */
  function switchTab(id) {
    panels.forEach(p => {
      const match = p.id === 'panel-' + id;
      p.hidden = !match;
      p.classList.toggle('is-active', match);
    });
    navBtns.forEach(b => {
      const active = b.dataset.tab === id;
      b.classList.toggle('is-active', active);
      b.setAttribute('aria-selected', String(active));
      
      if(active && window.innerWidth <= 767) {
        b.scrollIntoView({ behavior: 'smooth', block: 'nearest', inline: 'center' });
      }
    });

    history.replaceState(null, '', '#' + id);
  }

  navBtns.forEach(b => b.addEventListener('click', () => switchTab(b.dataset.tab)));

  const initHash = window.location.hash.slice(1);
  const validIds = ['orders', 'addresses', 'wishlist', 'details'];
  if (initHash && validIds.includes(initHash)) switchTab(initHash);

  /* ── Account Details: Read/Edit Mode Toggle ─────────────── */
  const toggleEditBtn = document.getElementById('ToggleEditDetailsBtn');
  const cancelEditBtn = document.getElementById('CancelEditDetailsBtn');
  const readMode      = document.getElementById('DetailsReadMode');
  const editMode      = document.getElementById('DetailsEditMode');

  function setEditMode(isEditing) {
    if(!readMode || !editMode) return;
    readMode.hidden = isEditing;
    editMode.hidden = !isEditing;
    if(toggleEditBtn) toggleEditBtn.style.display = isEditing ? 'none' : 'inline-flex';
  }

  toggleEditBtn?.addEventListener('click', () => setEditMode(true));
  cancelEditBtn?.addEventListener('click', () => setEditMode(false));

  /* ── Address Form Toggle ───────────────────────────────── */
  const toggleNewAddressBtn = document.getElementById('ToggleNewAddressBtn');
  const emptyAddAddressBtn  = document.getElementById('EmptyAddAddressBtn');
  const cancelNewAddressBtn = document.getElementById('CancelNewAddressBtn');
  const newAddressFormWrap  = document.getElementById('NewAddressFormWrap');

  function toggleAddressForm(show) {
    if (!newAddressFormWrap) return;
    const isShowing = show !== undefined ? show : (newAddressFormWrap.style.display === 'none');
    newAddressFormWrap.style.display = isShowing ? 'block' : 'none';
    if (toggleNewAddressBtn) {
      toggleNewAddressBtn.textContent = isShowing ? 'Cancel' : 'Add Address';
    }
    if (isShowing) {
      newAddressFormWrap.scrollIntoView({ behavior: 'smooth', block: 'nearest' });
    }
  }

  toggleNewAddressBtn?.addEventListener('click', () => toggleAddressForm());
  emptyAddAddressBtn?.addEventListener('click', () => toggleAddressForm(true));
  cancelNewAddressBtn?.addEventListener('click', () => toggleAddressForm(false));

  /* ── Custom Select Component ───────────────────────────── */
  const nativeSelect = document.getElementById('NewCountry');
  const trigger = document.getElementById('CountrySelectTrigger');
  const triggerText = trigger?.querySelector('.custom-select-trigger-text');
  const optionsContainer = document.getElementById('CountrySelectOptions');
  const optionsList = optionsContainer?.querySelector('.custom-select-options');

  if (nativeSelect && trigger && optionsList && optionsContainer) {
    const options = nativeSelect.querySelectorAll('option');
    optionsList.innerHTML = '';
    
    let activeIndex = nativeSelect.selectedIndex >= 0 ? nativeSelect.selectedIndex : 0;
    
    options.forEach((opt, idx) => {
      const li = document.createElement('li');
      li.className = 'custom-select-option';
      li.textContent = opt.textContent;
      li.dataset.value = opt.value;
      if (idx === activeIndex) {
        li.classList.add('is-selected');
        if (triggerText) triggerText.textContent = opt.textContent;
      }
      
      li.addEventListener('click', () => {
        optionsList.querySelectorAll('.custom-select-option').forEach(item => item.classList.remove('is-selected'));
        li.classList.add('is-selected');
        if (triggerText) triggerText.textContent = opt.textContent;
        nativeSelect.value = opt.value;
        nativeSelect.dispatchEvent(new Event('change'));
        optionsContainer.classList.remove('is-open');
        trigger.classList.remove('is-open');
      });
      
      optionsList.appendChild(li);
    });

    trigger.addEventListener('click', (e) => {
      e.stopPropagation();
      const isOpen = optionsContainer.classList.contains('is-open');
      optionsContainer.classList.toggle('is-open', !isOpen);
      trigger.classList.toggle('is-open', !isOpen);
    });

    document.addEventListener('click', (e) => {
      if (!optionsContainer.contains(e.target) && e.target !== trigger) {
        optionsContainer.classList.remove('is-open');
        trigger.classList.remove('is-open');
      }
    });
  }

  /* ── Toast ──────────────────────────────────────────────── */
  function showToast(msg, dur) {
    if (!toast) return;
    toast.textContent = msg;
    toast.classList.add('is-visible');
    setTimeout(() => toast.classList.remove('is-visible'), dur || 3000);
  }

  if (location.search.includes('customer_updated')) showToast('Details saved.');
  if (location.search.includes('address_saved'))    showToast('Address saved.');

  document.getElementById('DetailsSaveBtn')
    ?.closest('form')
    ?.addEventListener('submit', () => showToast('Saving…', 10000));

  document.getElementById('NewAddressForm')
    ?.addEventListener('submit', () => showToast('Saving address…', 10000));

  /* ── Wishlist panel: re-check empty state on open ───────── */
  document.querySelector('[data-tab="wishlist"]')?.addEventListener('click', () => {
    setTimeout(() => {
      const grid  = document.getElementById('WishlistGrid');
      const empty = document.getElementById('WishlistEmpty');
      if (!grid || !empty) return;
      empty.style.display = grid.querySelector('.wishlist-card') ? 'none' : '';
    }, 50);
  });

  /* ── Custom Delete Confirmation ─────────────────────────── */
  const deleteModal = document.getElementById('ConfirmDeleteModal');
  const cancelBtn = document.getElementById('CancelDeleteBtn');
  const confirmBtn = document.getElementById('ConfirmDeleteBtn');
  let formToSubmit = null;

  document.querySelectorAll('.js-delete-address-btn').forEach(btn => {
    btn.addEventListener('click', (e) => {
      formToSubmit = e.target.closest('form');
      if (deleteModal) deleteModal.hidden = false;
    });
  });

  if (cancelBtn) {
    cancelBtn.addEventListener('click', () => {
      if (deleteModal) deleteModal.hidden = true;
      formToSubmit = null;
    });
  }

  if (confirmBtn) {
    confirmBtn.addEventListener('click', () => {
      if (formToSubmit) formToSubmit.submit();
    });
  }
})();
</script>

{% schema %}
{
  "name": "Account Dashboard",
  "settings": []
}
{% endschema %}
