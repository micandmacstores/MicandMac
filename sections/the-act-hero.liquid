{%- style -%}
  .section-{{ section.id }}-padding {
    padding-top: {{ section.settings.padding_top | times: 0.75 | round: 0 }}px;
    padding-bottom: {{ section.settings.padding_bottom | times: 0.75 | round: 0 }}px;
  }
  @media screen and (min-width: 750px) {
    .section-{{ section.id }}-padding {
      padding-top: {{ section.settings.padding_top }}px;
      padding-bottom: {{ section.settings.padding_bottom }}px;
    }
  }

  .the-act-hero {
    position: relative;
    width: 100%;
    padding: 0 1rem;
  }

  .hero-card {
    position: relative;
    border-radius: 40px;
    overflow: hidden;
    min-height: 500px;
    height: 80vh;
    background-color: var(--mm-deep-garnet);
    display: flex;
    flex-direction: column;
  }

  .hero-bg-placeholder {
    position: absolute;
    inset: 0;
    background: var(--mm-deep-garnet);
  }

  @media screen and (min-width: 1024px) {
    .hero-card {
      height: 90vh;
      border-radius: 60px;
    }
  }

  .hero-bg-image {
    position: absolute;
    inset: 0;
    width: 100%;
    height: 100%;
    object-fit: cover;
    z-index: 0;
  }

  .hero-overlay {
    position: absolute;
    inset: 0;
    background: linear-gradient(
      to top,
      rgba(46, 31, 26, 0.80) 0%,
      rgba(46, 31, 26, 0.45) 45%,
      rgba(46, 31, 26, 0.10) 100%
    );
    z-index: 1;
  }

  .hero-content {
    position: relative;
    z-index: 10;
    height: 100%;
    padding: 2rem;
    display: flex;
    flex-direction: column;
    justify-content: space-between;
  }

  @media screen and (min-width: 1024px) {
    .hero-content {
      padding: 3rem 4rem;
    }
  }

  .hero-header {
    display: flex;
    justify-content: space-between;
    align-items: center;
    width: 100%;
  }

  .hero-logo {
    font-size: 1.5rem;
    font-weight: 500;
    color: #1a1a1a;
  }

  .hero-nav {
    display: none;
  }
  
  @media screen and (min-width: 768px) {
    .hero-nav {
      display: flex;
      gap: 1.5rem;
      background: rgba(255, 255, 255, 0.4);
      backdrop-filter: blur(8px);
      padding: 0.5rem 1.5rem;
      border-radius: 100px;
      align-items: center;
    }
  }

  .hero-nav a {
    font-size: 0.875rem;
    color: #1a1a1a;
    text-decoration: none;
    transition: opacity 0.2s;
  }

  .hero-nav a:hover {
    opacity: 0.7;
  }

  .contact-btn {
    background: #1a1a1a;
    color: white !important;
    padding: 0.5rem 1.25rem;
    border-radius: 100px;
  }

  .hero-main {
    flex-grow: 1;
    display: flex;
    flex-direction: column;
    justify-content: flex-end;
    padding-bottom: 2rem;
    max-width: 560px;
  }

  .hero-eyebrow {
    font-family: var(--font-body);
    font-size: 10px;
    font-weight: 500;
    letter-spacing: 0.22em;
    text-transform: uppercase;
    color: var(--mm-champagne-gold);
    margin-bottom: 1rem;
    display: block;
  }

  .hero-heading {
    font-family: var(--font-display);
    font-size: 2.5rem;
    line-height: 1.1;
    color: var(--mm-soft-blush);
    margin-bottom: 1.5rem;
    font-weight: 300;
  }

  .hero-heading .script-letter {
    font-family: var(--font-script);
    font-size: 1.35em;
    font-weight: 400;
    line-height: 0.8;
    display: inline-block;
    vertical-align: baseline;
    color: var(--mm-champagne-gold);
  }

  @media screen and (min-width: 1024px) {
    .hero-heading {
      font-size: 4.25rem;
    }
  }

  .hero-subhead {
    font-family: var(--font-body);
    font-size: 1rem;
    line-height: 1.7;
    color: rgba(243, 232, 228, 0.72);
    max-width: 420px;
    margin-bottom: 2rem;
  }

  .hero-cta {
    display: inline-flex;
    align-items: center;
    gap: 8px;
    background: var(--mm-champagne-gold);
    color: var(--mm-dark-espresso);
    padding: 14px 28px;
    border-radius: var(--radius-pill);
    font-family: var(--font-body);
    font-size: 13px;
    font-weight: 600;
    letter-spacing: 0.06em;
    text-transform: uppercase;
    text-decoration: none;
    transition: transform 250ms cubic-bezier(0.25, 0.46, 0.45, 0.94),
                background 250ms ease,
                box-shadow 250ms ease;
    align-self: flex-start;
  }

  .hero-cta:hover {
    background: var(--color-gold-light);
    transform: translateY(-2px) scale(1.02);
    box-shadow: 0 6px 24px rgba(46, 31, 26, 0.3);
  }

  .floating-mission {
    background: rgba(255, 255, 255, 0.4);
    backdrop-filter: blur(12px);
    border-radius: 24px;
    padding: 1rem;
    display: flex;
    gap: 1rem;
    max-width: 400px;
    align-items: center;
    margin-top: 1.5rem;
  }

  .mission-thumb {
    width: 60px;
    height: 60px;
    border-radius: 12px;
    object-fit: cover;
  }

  .mission-text {
    font-size: 0.75rem;
    line-height: 1.4;
    color: var(--mm-dark-espresso);
  }

  .mission-text b {
    display: block;
    font-weight: 600;
    margin-bottom: 0.25rem;
  }

  .floating-product {
    position: absolute;
    right: 2rem;
    bottom: 4rem;
    background: rgba(255, 255, 255, 0.4);
    backdrop-filter: blur(12px);
    border-radius: 24px;
    padding: 1.5rem;
    width: 240px;
    display: none;
    z-index: 20;
  }

  @media screen and (min-width: 1024px) {
    .floating-product {
      display: block;
    }
  }

  .product-tag {
    font-size: 0.70rem;
    background: white;
    padding: 0.2rem 0.6rem;
    border-radius: 100px;
    display: inline-block;
    margin-bottom: 1rem;
    color: #666;
  }

  .product-title {
    font-size: 1.25rem;
    font-weight: 500;
    color: #1a1a1a;
    margin-bottom: 1rem;
    line-height: 1.2;
  }

  .product-image-container {
    background: white;
    border-radius: 16px;
    padding: 1rem;
    display: flex;
    justify-content: center;
    align-items: center;
  }

  .product-image-container img {
    max-width: 100%;
    height: auto;
  }

  .arrow-icon {
    position: absolute;
    top: 1.5rem;
    right: 1.5rem;
    width: 24px;
    height: 24px;
    background: white;
    border-radius: 50%;
    display: flex;
    align-items: center;
    justify-content: center;
  }
{%- endstyle -%}

<div class="the-act-hero section-{{ section.id }}-padding">
  <div class="hero-card" data-has-video="{% if section.settings.video_url != blank or section.settings.background_video != blank %}true{% else %}false{% endif %}">

    {%- comment -%} Layer 0: Video background (highest priority) {%- endcomment -%}
    {%- if section.settings.background_video != blank -%}
      <video
        class="hero-bg-image"
        autoplay muted loop playsinline
        style="object-fit:cover;"
      >
        {%- for source in section.settings.background_video.sources -%}
          <source src="{{ source.url }}" type="{{ source.mime_type }}">
        {%- endfor -%}
      </video>
    {%- elsif section.settings.video_url != blank -%}
      <video
        class="hero-bg-image"
        src="{{ section.settings.video_url }}"
        autoplay muted loop playsinline
        style="object-fit:cover;"
      ></video>
    {%- elsif section.settings.image != blank -%}
      <img
        src="{{ section.settings.image | image_url: width: 2000 }}"
        alt="{{ section.settings.image.alt | escape }}"
        class="hero-bg-image"
        width="2000"
        height="{{ 2000 | divided_by: section.settings.image.aspect_ratio | round }}"
      >
    {%- else -%}
      {%- comment -%}
        No image or video set yet - brand film coming.
        The Three.js particle canvas in cinematic.js will render
        on top of the deep garnet CSS background.
      {%- endcomment -%}
      <div class="hero-bg-placeholder" aria-hidden="true"></div>
    {%- endif -%}

    <div class="hero-overlay"></div>

    <div class="hero-content">
      <header class="hero-header">
        <div class="hero-logo">
          {%- if section.settings.logo != blank -%}
            <img src="{{ section.settings.logo | image_url: width: 200 }}" alt="{{ shop.name }}" width="100" height="40">
          {%- else -%}
            the act
          {%- endif -%}
        </div>

        {%- if section.settings.show_hero_nav -%}
          <nav class="hero-nav">
            <a href="{{ routes.all_products_collection_url }}">Catalog</a>
            <a href="/pages/about">About Us</a>
            <a href="/pages/reviews">Reviews</a>
            <a href="/pages/contact" class="contact-btn">Contact Us</a>
          </nav>
        {%- endif -%}
      </header>

      <div class="hero-main">
        {%- if section.settings.eyebrow != blank -%}
          <span class="hero-eyebrow">{{ section.settings.eyebrow }}</span>
        {%- endif -%}

        <h1 class="hero-heading">
          {%- assign heading_text = section.settings.heading -%}
          {%- if heading_text != blank -%}
            {%- assign first_char = heading_text | slice: 0 -%}
            {%- assign rest_text = heading_text | remove_first: first_char -%}
            <span class="script-letter">{{ first_char }}</span>{{ rest_text }}
          {%- endif -%}
        </h1>

        {%- if section.settings.subheading != blank -%}
          <p class="hero-subhead">{{ section.settings.subheading }}</p>
        {%- endif -%}

        {%- if section.settings.cta_label != blank -%}
          <a href="{{ section.settings.cta_url | default: routes.all_products_collection_url }}" class="hero-cta">
            {{ section.settings.cta_label }}
            <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round">
              <path d="M5 12h14M12 5l7 7-7 7"/>
            </svg>
          </a>
        {%- endif -%}

        {%- if section.settings.mission_title != blank -%}
          <div class="floating-mission">
            {%- if section.settings.mission_image != blank -%}
              <img src="{{ section.settings.mission_image | image_url: width: 120 }}" class="mission-thumb" alt="Mission" width="60" height="60">
            {%- endif -%}
            <div class="mission-text">
              <b>{{ section.settings.mission_title }}</b>
              {{ section.settings.mission_text }}
            </div>
          </div>
        {%- endif -%}
      </div>

      <div class="floating-product">
        <div class="product-tag">{{ section.settings.product_tag }}</div>
        <div class="arrow-icon">
          <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M7 17l10-10M7 7h10v10"></path></svg>
        </div>
        <h2 class="product-title">{{ section.settings.product_title }}</h2>
        <div class="product-image-container">
          {%- if section.settings.featured_product_image != blank -%}
            <img src="{{ section.settings.featured_product_image | image_url: width: 400 }}" alt="{{ section.settings.product_title }}" width="200" height="150">
          {%- endif -%}
        </div>
      </div>
    </div>
  </div>
</div>

{% schema %}
{
  "name": "The Act Hero",
  "tag": "section",
  "class": "section",
  "settings": [
    {
      "type": "header",
      "content": "Background Media"
    },
    {
      "type": "video",
      "id": "background_video",
      "label": "Background video (upload MP4 via Files)"
    },
    {
      "type": "url",
      "id": "video_url",
      "label": "Background video URL (paste CDN link)",
      "info": "Alternative: paste a direct .mp4 URL if not uploading via Shopify Files"
    },
    {
      "type": "image_picker",
      "id": "image",
      "label": "Background image (fallback if no video)"
    },
    {
      "type": "image_picker",
      "id": "logo",
      "label": "Hero Logo (Overlay)"
    },
    {
      "type": "checkbox",
      "id": "show_hero_nav",
      "label": "Show Hero internal navigation",
      "default": true
    },
    {
      "type": "text",
      "id": "eyebrow",
      "label": "Eyebrow label"
    },
    {
      "type": "textarea",
      "id": "heading",
      "label": "Heading"
    },
    {
      "type": "textarea",
      "id": "subheading",
      "label": "Subheading"
    },
    {
      "type": "text",
      "id": "cta_label",
      "label": "CTA Button label"
    },
    {
      "type": "url",
      "id": "cta_url",
      "label": "CTA Button link"
    },
    {
      "type": "header",
      "content": "Mission Card (optional)"
    },
    {
      "type": "image_picker",
      "id": "mission_image",
      "label": "Mission Portrait"
    },
    {
      "type": "text",
      "id": "mission_title",
      "label": "Mission Title"
    },
    {
      "type": "textarea",
      "id": "mission_text",
      "label": "Mission Text"
    },
    {
      "type": "header",
      "content": "Product Card"
    },
    {
      "type": "text",
      "id": "product_tag",
      "label": "Product Tag"
    },
    {
      "type": "text",
      "id": "product_title",
      "label": "Product Title"
    },
    {
      "type": "image_picker",
      "id": "featured_product_image",
      "label": "Featured Product Image"
    },
    {
      "type": "header",
      "content": "Spacing"
    },
    {
      "type": "range",
      "id": "padding_top",
      "min": 0,
      "max": 100,
      "step": 4,
      "unit": "px",
      "label": "Padding Top",
      "default": 36
    },
    {
      "type": "range",
      "id": "padding_bottom",
      "min": 0,
      "max": 100,
      "step": 4,
      "unit": "px",
      "label": "Padding Bottom",
      "default": 36
    }
  ],
  "presets": [
    {
      "name": "The Act Hero"
    }
  ]
}
{% endschema %}
