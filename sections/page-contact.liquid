{% comment %}Section: Contact{% endcomment %}

<div class="page-contact section-padding">
  <div class="container">
    <div class="page-contact__layout">

      <!-- Info side -->
      <div class="page-contact__info">
        <p class="eyebrow">{{ section.settings.eyebrow | default: 'Get in Touch' }}</p>
        <h1 class="page-contact__title">{{ section.settings.heading | default: "We'd Love to Hear From You" }}</h1>
        <p class="page-contact__sub">{{ section.settings.subtext | default: "Questions about your order, partnerships, or press enquiries - we're here." }}</p>

        <div class="contact-info-items">
          {%- if section.settings.email != blank -%}
            <a href="mailto:{{ section.settings.email }}" class="contact-info-item">
              <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" aria-hidden="true"><path d="M4 4h16c1.1 0 2 .9 2 2v12c0 1.1-.9 2-2 2H4c-1.1 0-2-.9-2-2V6c0-1.1.9-2 2-2z"/><polyline points="22,6 12,13 2,6"/></svg>
              {{ section.settings.email }}
            </a>
          {%- endif -%}
          {%- if section.settings.whatsapp != blank -%}
            <a href="https://wa.me/{{ section.settings.whatsapp | remove: '+' | remove: ' ' }}" class="contact-info-item" target="_blank" rel="noopener">
              <svg width="18" height="18" viewBox="0 0 24 24" fill="currentColor" aria-hidden="true"><path d="M17.472 14.382c-.297-.149-1.758-.867-2.03-.967-.273-.099-.471-.148-.67.15-.197.297-.767.966-.94 1.164-.173.199-.347.223-.644.075-.297-.15-1.255-.463-2.39-1.475-.883-.788-1.48-1.761-1.653-2.059-.173-.297-.018-.458.13-.606.134-.133.298-.347.446-.52.149-.174.198-.298.298-.497.099-.198.05-.371-.025-.52-.075-.149-.669-1.612-.916-2.207-.242-.579-.487-.5-.669-.51-.173-.008-.371-.01-.57-.01-.198 0-.52.074-.792.372-.272.297-1.04 1.016-1.04 2.479 0 1.462 1.065 2.875 1.213 3.074.149.198 2.096 3.2 5.077 4.487.709.306 1.262.489 1.694.625.712.227 1.36.195 1.871.118.571-.085 1.758-.719 2.006-1.413.248-.694.248-1.289.173-1.413-.074-.124-.272-.198-.57-.347m-5.421 7.403h-.004a9.87 9.87 0 01-5.031-1.378l-.361-.214-3.741.982.998-3.648-.235-.374a9.86 9.86 0 01-1.51-5.26c.001-5.45 4.436-9.884 9.888-9.884 2.64 0 5.122 1.03 6.988 2.898a9.825 9.825 0 012.893 6.994c-.003 5.45-4.437 9.884-9.885 9.884m8.413-18.297A11.815 11.815 0 0012.05 0C5.495 0 .16 5.335.157 11.892c0 2.096.547 4.142 1.588 5.945L.057 24l6.305-1.654a11.882 11.882 0 005.683 1.448h.005c6.554 0 11.89-5.335 11.893-11.893a11.821 11.821 0 00-3.48-8.413z"/></svg>
              {{ section.settings.whatsapp }}
            </a>
          {%- endif -%}
          {%- if section.settings.hours != blank -%}
            <div class="contact-info-item contact-info-item--text">
              <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" aria-hidden="true"><circle cx="12" cy="12" r="10"/><polyline points="12 6 12 12 16 14"/></svg>
              {{ section.settings.hours }}
            </div>
          {%- endif -%}
        </div>
      </div>

      <!-- Form side -->
      <div class="page-contact__form-wrap">
        {%- if form.posted_successfully? -%}
          <div class="contact-success">
            <svg width="40" height="40" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M22 11.08V12a10 10 0 1 1-5.93-9.14"/><polyline points="22 4 12 14.01 9 11.01"/></svg>
            <h3>Message sent!</h3>
            <p>We'll get back to you within 24 hours.</p>
          </div>
        {%- else -%}
          {%- form 'contact', id: 'ContactForm' -%}
            {%- if form.errors -%}
              <div class="form-error">{{ form.errors | default_errors }}</div>
            {%- endif -%}
            <div class="contact-form__row">
              <div class="form-group">
                <label for="ContactName" class="form-label">Name</label>
                <input type="text" id="ContactName" name="contact[name]" class="form-input" required>
              </div>
              <div class="form-group">
                <label for="ContactEmail" class="form-label">Email</label>
                <input type="email" id="ContactEmail" name="contact[email]" autocomplete="email" class="form-input" required>
              </div>
            </div>
            <div class="form-group">
              <label for="ContactPhone" class="form-label">Phone (optional)</label>
              <input type="tel" id="ContactPhone" name="contact[phone]" class="form-input">
            </div>
            <div class="form-group">
              <label for="ContactSubject" class="form-label">Subject</label>
              <select id="ContactSubject" name="contact[subject]" class="form-select form-input">
                <option value="">Select a topic…</option>
                <option>Order enquiry</option>
                <option>Product question</option>
                <option>Partnership / wholesale</option>
                <option>Press / media</option>
                <option>Other</option>
              </select>
            </div>
            <div class="form-group">
              <label for="ContactMessage" class="form-label">Message</label>
              <textarea id="ContactMessage" name="contact[body]" class="form-input form-textarea" rows="5" required></textarea>
            </div>
            <button type="submit" class="btn btn--primary btn--lg" id="ContactSubmit">Send Message</button>
          {%- endform -%}
        {%- endif -%}
      </div>

    </div>
  </div>
</div>

<style>
.page-contact__layout { display: grid; grid-template-columns: 1fr 1fr; gap: var(--space-12); align-items: start; }
.page-contact__title { font-family: var(--font-display); font-size: clamp(2rem,4vw,3rem); font-weight: 300; margin-block: var(--space-3) var(--space-4); }
.page-contact__sub { font-size: var(--text-base); color: var(--color-text-mid); line-height: 1.7; margin-bottom: var(--space-8); }
.contact-info-items { display: flex; flex-direction: column; gap: var(--space-4); }
.contact-info-item { display: flex; align-items: center; gap: var(--space-3); font-size: var(--text-base); color: var(--color-text-mid); text-decoration: none; transition: color var(--transition-fast); }
.contact-info-item:hover { color: var(--color-forest); }
.contact-info-item svg { color: var(--color-forest); flex-shrink: 0; }
.contact-form__row { display: grid; grid-template-columns: 1fr 1fr; gap: var(--space-4); }
.form-textarea { resize: vertical; min-height: 120px; }
.contact-success { text-align: center; padding: var(--space-12); display: flex; flex-direction: column; align-items: center; gap: var(--space-4); }
.contact-success svg { color: var(--color-forest); }
.contact-success h3 { font-family: var(--font-display); font-size: var(--text-2xl); font-weight: 400; }
.contact-success p { color: var(--color-text-mid); }
@media (max-width: 767px) {
  .page-contact__layout { grid-template-columns: 1fr; }
  .contact-form__row { grid-template-columns: 1fr; }
}
</style>

{% schema %}
{
  "name": "Contact page",
  "settings": [
    { "type": "text", "id": "eyebrow", "label": "Eyebrow" },
    { "type": "text", "id": "heading", "label": "Heading" },
    { "type": "text", "id": "subtext", "label": "Subtext" },
    { "type": "text", "id": "email", "label": "Email address" },
    { "type": "text", "id": "whatsapp", "label": "WhatsApp number" },
    { "type": "text", "id": "hours", "label": "Support hours", "default": "Mon–Sat, 10am–6pm IST" }
  ]
}
{% endschema %}
