{% comment %}Section: Main Login{% endcomment %}

<div class="minimal-auth-page section-padding">
  <div class="minimal-auth-container">
    
    <!-- Centered Brand -->
    <div class="minimal-auth-brand">
      <a href="{{ routes.root_url }}">
        <img src="{{ 'MicandMac_Monogram.webp' | asset_url }}" alt="Mic &amp; Mac" width="48" height="48">
        <span>MIC &amp; MAC</span>
      </a>
    </div>

    <div class="minimal-auth-header">
      <h1 class="minimal-auth-title">Sign in</h1>
      <p class="minimal-auth-subtitle">Sign in or <a href="{{ routes.account_register_url }}" style="color: inherit; text-decoration: underline;">create an account</a></p>
    </div>

    {%- if form.errors -%}
      <div class="minimal-auth-error" role="alert">
        <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><circle cx="12" cy="12" r="10"/><line x1="12" y1="8" x2="12" y2="12"/><line x1="12" y1="16" x2="12.01" y2="16"/></svg>
        {{ form.errors | default_errors }}
      </div>
    {%- endif -%}

    {%- form 'customer_login', id: 'MinimalLoginForm' -%}
      <input type="hidden" name="return_to" value="/pages/my-account">
      <div class="minimal-auth-field">
        <label for="MinimalLoginEmail" class="visually-hidden">Email</label>
        <input type="email" id="MinimalLoginEmail" name="customer[email]" autocomplete="email" class="minimal-auth-input" placeholder="Email" required autofocus>
      </div>

      <div class="minimal-auth-field">
        <div class="minimal-auth-input-wrapper">
          <label for="MinimalLoginPassword" class="visually-hidden">Password</label>
          <input type="password" id="MinimalLoginPassword" name="customer[password]" autocomplete="current-password" class="minimal-auth-input" placeholder="Password" required>
          <button type="button" class="password-toggle" data-password-toggle aria-label="Show password">
            <svg class="eye-open" width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M1 12s4-8 11-8 11 8 11 8-4 8-11 8-11-8-11-8z"/><circle cx="12" cy="12" r="3"/></svg>
            <svg class="eye-closed" width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" style="display:none;"><path d="M17.94 17.94A10.07 10.07 0 0 1 12 20c-7 0-11-8-11-8a18.45 18.45 0 0 1 5.06-5.94M9.9 4.24A9.12 9.12 0 0 1 12 4c7 0 11 8 11 8a18.5 18.5 0 0 1-2.16 3.19m-6.72-1.07a3 3 0 1 1-4.24-4.24"></path><line x1="1" y1="1" x2="23" y2="23"></line></svg>
          </button>
        </div>
      </div>

      <a href="{{ routes.account_recover_url }}" class="minimal-auth-forgot">Forgot password?</a>

      <button type="submit" class="minimal-auth-cta">Continue</button>
    {%- endform -%}

    <div class="minimal-auth-footer">
      <a href="/policies/privacy-policy">Privacy policy</a>
    </div>

  </div>
</div>

<style>
.minimal-auth-page {
  min-height: 80vh;
  display: flex;
  align-items: center;
  justify-content: center;
  background: #ffffff;
}

.minimal-auth-container {
  width: 100%;
  max-width: 400px;
  padding: 40px 20px;
}

.minimal-auth-brand {
  text-align: center;
  margin-bottom: 48px;
}

.minimal-auth-brand a {
  display: inline-flex;
  flex-direction: column;
  align-items: center;
  text-decoration: none;
  color: #2E1F1A;
}

.minimal-auth-brand img {
  margin-bottom: 12px;
}

.minimal-auth-brand span {
  font-family: 'DM Sans', sans-serif;
  font-size: 0.8rem;
  font-weight: 600;
  letter-spacing: 0.15em;
  text-transform: uppercase;
}

.minimal-auth-header {
  margin-bottom: 32px;
}

.minimal-auth-title {
  font-family: 'Cormorant Garamond', Georgia, serif;
  font-size: 1.8rem;
  font-weight: 600;
  color: #2E1F1A;
  margin-bottom: 8px;
}

.minimal-auth-subtitle {
  font-size: 0.95rem;
  color: #555;
}

.minimal-auth-error {
  display: flex;
  align-items: flex-start;
  gap: 8px;
  background: #fff4f4;
  border: 1px solid #f5c0c0;
  border-radius: 8px;
  padding: 12px 14px;
  font-size: 0.85rem;
  color: #8B2020;
  margin-bottom: 24px;
}

.minimal-auth-field {
  margin-bottom: 16px;
  position: relative;
}

.minimal-auth-input-wrapper {
  position: relative;
  width: 100%;
}

.minimal-auth-input {
  width: 100%;
  height: 52px;
  border: 1px solid #c9c9c9;
  border-radius: 8px;
  padding: 0 16px;
  font-family: 'DM Sans', sans-serif;
  font-size: 1rem;
  color: #2E1F1A;
  background: transparent;
  outline: none;
  transition: border-color 0.2s;
}

.minimal-auth-input::placeholder {
  color: #767676;
}

.minimal-auth-input:focus {
  border-color: #2E1F1A;
  border-width: 2px;
  padding: 0 15px; /* Offset for border width */
}

.minimal-auth-forgot {
  display: inline-block;
  font-size: 0.85rem;
  color: #2E1F1A;
  text-decoration: underline;
  margin-bottom: 24px;
}

.minimal-auth-forgot:hover {
  text-decoration: none;
}

.minimal-auth-cta {
  width: 100%;
  height: 52px;
  background: #4B2A31;
  color: #fff;
  border: none;
  border-radius: 8px;
  font-family: 'DM Sans', sans-serif;
  font-size: 1rem;
  font-weight: 600;
  cursor: pointer;
  transition: opacity 0.2s;
}

.minimal-auth-cta:hover {
  opacity: 0.9;
}

.password-toggle {
  position: absolute;
  top: 50%;
  right: 12px;
  transform: translateY(-50%);
  background: transparent;
  border: none;
  color: #555;
  cursor: pointer;
  padding: 4px;
  display: flex;
  align-items: center;
  justify-content: center;
  transition: color 0.2s ease;
  z-index: 2;
}

.password-toggle:hover {
  color: #2E1F1A;
}

.visually-hidden {
  position: absolute;
  width: 1px;
  height: 1px;
  margin: -1px;
  padding: 0;
  overflow: hidden;
  clip: rect(0, 0, 0, 0);
  border: 0;
}

.minimal-auth-footer {
  margin-top: 64px;
  text-align: center;
}

.minimal-auth-footer a {
  font-size: 0.8rem;
  color: #555;
  text-decoration: none;
}

.minimal-auth-footer a:hover {
  text-decoration: underline;
}
</style>
