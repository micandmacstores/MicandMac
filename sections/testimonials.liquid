{%- style -%}
  .section-{{ section.id }}-padding {
    padding-top: {{ section.settings.padding_top | times: 0.75 | round: 0 }}px;
    padding-bottom: {{ section.settings.padding_bottom | times: 0.75 | round: 0 }}px;
  }
  @media screen and (min-width: 750px) {
    .section-{{ section.id }}-padding {
      padding-top: {{ section.settings.padding_top }}px;
      padding-bottom: {{ section.settings.padding_bottom }}px;
    }
  }
{%- endstyle -%}

<div class="testimonials section-{{ section.id }}-padding bg-{{ section.settings.color_scheme }}" id="Testimonials-{{ section.id }}">
  <div class="container px-4">
    <div class="text-center max-w-2xl mx-auto mb-12">
      {%- if section.settings.heading != blank -%}
        <h2 class="text-3xl md:text-5xl font-light mb-4" style="font-family: var(--font-display);">{{ section.settings.heading }}</h2>
      {%- endif -%}
      {%- if section.settings.text != blank -%}
        <p class="text-base text-gray-600">{{ section.settings.text }}</p>
      {%- endif -%}
    </div>

    <!-- Swiper container for testimonials (relies on CSS scroll snap for simplicity without JS library) -->
    <div class="testimonials__slider relative -mx-4 px-4 overflow-x-auto snap-x snap-mandatory hide-scrollbar">
      <div class="flex gap-4 md:gap-6 w-max pb-4 md:grid md:grid-cols-3 md:w-full">
        {%- for block in section.blocks -%}
          <div class="w-[85vw] max-w-[340px] md:w-full snap-start shrink-0" {{ block.shopify_attributes }}>
            <div class="h-full bg-white p-6 md:p-8 rounded-2xl shadow-sm border border-gray-100 flex flex-col">
              {%- if block.settings.rating > 0 -%}
                <div class="text-yellow-400 text-sm mb-4">
                  {% render 'star-rating', rating: block.settings.rating, count: 0 %}
                </div>
              {%- endif -%}
              
              <h3 class="text-lg font-medium text-gray-900 mb-2">{{ block.settings.title }}</h3>
              
              <blockquote class="text-gray-600 mb-6 flex-grow">
                "{{ block.settings.text }}"
              </blockquote>
              
              <div class="flex items-center gap-3">
                {%- if block.settings.image != blank -%}
                  <img src="{{ block.settings.image | image_url: width: 80 }}" alt="{{ block.settings.author }}" width="40" height="40" class="w-10 h-10 rounded-full object-cover">
                {%- else -%}
                  <div class="w-10 h-10 rounded-full bg-primary-100 text-primary flex items-center justify-center font-bold text-sm">
                    {{ block.settings.author | slice: 0, 1 | upcase }}
                  </div>
                {%- endif -%}
                <div>
                  <div class="font-medium text-sm text-gray-900">{{ block.settings.author }}</div>
                  {%- if block.settings.product_title != blank -%}
                    <div class="text-xs text-gray-500">Verified buyer - <span class="bg-gray-100 px-1 rounded">{{ block.settings.product_title }}</span></div>
                  {%- else -%}
                    <div class="text-xs text-gray-500">Verified buyer</div>
                  {%- endif -%}
                </div>
              </div>
            </div>
          </div>
        {%- endfor -%}
      </div>
    </div>
  </div>
</div>

{% schema %}
{
  "name": "Testimonials",
  "tag": "section",
  "class": "section",
  "settings": [
    {
      "type": "text",
      "id": "heading",
      "label": "Heading",
      "default": "Real results, real talk."
    },
    {
      "type": "textarea",
      "id": "text",
      "label": "Description",
      "default": "Don't just take our word for it. Here is what our community is saying."
    },
    {
      "type": "select",
      "id": "color_scheme",
      "options": [
        {
          "value": "white",
          "label": "White"
        },
        {
          "value": "secondary",
          "label": "Secondary/Off-White"
        }
      ],
      "default": "secondary",
      "label": "Background Color"
    },
    {
      "type": "header",
      "content": "Section Padding"
    },
    {
      "type": "range",
      "id": "padding_top",
      "min": 0,
      "max": 100,
      "step": 4,
      "unit": "px",
      "label": "Padding Top",
      "default": 64
    },
    {
      "type": "range",
      "id": "padding_bottom",
      "min": 0,
      "max": 100,
      "step": 4,
      "unit": "px",
      "label": "Padding Bottom",
      "default": 64
    }
  ],
  "blocks": [
    {
      "type": "testimonial",
      "name": "Testimonial",
      "settings": [
        {
          "type": "range",
          "id": "rating",
          "min": 1,
          "max": 5,
          "step": 1,
          "default": 5,
          "label": "Star Rating (1-5)"
        },
        {
          "type": "text",
          "id": "title",
          "label": "Heading",
          "default": "Absolutely life-changing!"
        },
        {
          "type": "textarea",
          "id": "text",
          "label": "Review Text",
          "default": "I've tried so many products and this is the first one that actually delivered on its promises."
        },
        {
          "type": "text",
          "id": "author",
          "label": "Customer Name",
          "default": "Sarah J."
        },
        {
          "type": "image_picker",
          "id": "image",
          "label": "Customer Photo (Optional)"
        },
        {
          "type": "text",
          "id": "product_title",
          "label": "Bought Product (Optional)"
        }
      ]
    }
  ],
  "presets": [
    {
      "name": "Testimonials",
      "blocks": [
        { "type": "testimonial" },
        { "type": "testimonial" },
        { "type": "testimonial" }
      ]
    }
  ]
}
{% endschema %}
