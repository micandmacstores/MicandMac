{% comment %}
  Section: FAQ Accordion
  - Fast, smooth CSS-based max-height + opacity transition (250ms max).
  - Only one item opens at a time.
  - Minimal UI: clean typography, full-row clickable, subtle + to × icon animation.
{% endcomment %}

<section class="faq-section">
  <div class="faq-page-container">

    {%- if page.title != blank -%}
      <div class="faq-page-hero">
        <h1 class="faq-page-title">{{ page.title }}</h1>
        <div class="faq-page-divider"></div>
      </div>
    {%- endif -%}

    <div class="faq-layout">
      <!-- Left Info -->
      <div class="faq-layout__aside">
        <div class="section-heading" style="text-align: left; margin-bottom: 0;">
          <h2>{{ section.settings.heading | default: 'Frequently Asked Questions' }}</h2>
          <p class="faq-subtext">{{ section.settings.subtext | default: 'Everything you might want to know before you begin.' }}</p>
          
          {%- if section.settings.cta_label != blank -%}
            <div class="faq-section__footer" style="align-items: flex-start; margin-top: var(--space-8);">
              <p class="faq-section__cta-text">{{ section.settings.cta_prefix | default: 'Still have questions?' }}</p>
              <a href="{{ section.settings.cta_url | default: routes.root_url }}" class="btn btn--secondary">
                {{ section.settings.cta_label }}
              </a>
            </div>
          {%- endif -%}
        </div>
      </div>

      <!-- Right Accordion -->
      <div class="faq-layout__content">
        <div class="faq-accordion" id="FaqAccordion-{{ section.id }}">
          {%- for block in section.blocks -%}
            {%- if block.type == 'faq_item' -%}
              <div class="faq-item" {{ block.shopify_attributes }}>
                <button
                  class="faq-item__trigger"
                  aria-expanded="false"
                  aria-controls="faq-answer-{{ block.id }}"
                >
                  <span class="faq-item__question">{{ block.settings.question }}</span>
                  <span class="faq-item__icon" aria-hidden="true">
                    <!-- Clean Plus Icon -->
                    <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round">
                      <line x1="12" y1="5" x2="12" y2="19"></line>
                      <line x1="5" y1="12" x2="19" y2="12"></line>
                    </svg>
                  </span>
                </button>
                <div
                  class="faq-item__answer"
                  id="faq-answer-{{ block.id }}"
                  role="region"
                  aria-hidden="true"
                >
                  <div class="faq-item__answer-inner rte">
                    {{ block.settings.answer }}
                  </div>
                </div>
              </div>
            {%- endif -%}
          {%- endfor -%}
        </div>
      </div>
    </div>
  </div>
</section>

<style>
.faq-section {
  background-color: var(--color-bg-page, #F3E8E4);
  color: var(--mm-dark-espresso, #2E1F1A);
  font-family: var(--font-body);
}

.faq-page-container {
  max-width: 1140px;
  margin: 0 auto;
  padding: 6rem 1.5rem 8rem;
}

.faq-page-hero {
  margin-bottom: 4rem;
}

.faq-page-title {
  font-family: var(--font-display);
  font-size: clamp(2.5rem, 5vw, 4rem);
  font-weight: 300;
  color: var(--mm-deep-garnet, #4B2A31);
  margin-bottom: 1.5rem;
  line-height: 1.1;
}

.faq-page-divider {
  width: 60px;
  height: 2px;
  background-color: var(--mm-deep-garnet, #4B2A31);
  opacity: 0.3;
}

.faq-layout {
  display: grid;
  grid-template-columns: 1fr;
  gap: var(--space-8);
}
@media (min-width: 900px) {
  .faq-layout {
    grid-template-columns: 280px 1fr;
    gap: 5rem;
    align-items: start;
  }

  .faq-page-container {
    padding-top: 6rem;
  }
}

@media (max-width: 767px) {
  .faq-page-container {
    padding: 4rem 1.25rem 6rem;
  }
}

.faq-layout__aside h2 {
  font-family: var(--font-display);
  font-size: clamp(2rem, 4vw, 3rem);
  font-weight: 300;
  line-height: 1.2;
  color: var(--mm-deep-garnet, #4B2A31);
}

.faq-subtext {
  font-size: 1.05rem;
  color: var(--mm-dark-espresso, #2E1F1A);
  opacity: 0.85;
  margin-top: 0.75rem;
  line-height: 1.6;
}

.faq-accordion {
  display: flex;
  flex-direction: column;
  margin-bottom: var(--space-10);
  border-top: 1px solid rgba(46, 31, 26, 0.1);
}

.faq-item {
  border-bottom: 1px solid rgba(46, 31, 26, 0.1);
}

/* 1. Click area = Full row */
.faq-item__trigger {
  width: 100%;
  display: flex;
  align-items: center;
  justify-content: space-between;
  gap: var(--space-4);
  padding: 1.25rem 0;
  background: none;
  border: none;
  cursor: pointer;
  text-align: left;
}

/* Typography: 18-20px, medium weight */
.faq-item__question {
  font-family: var(--font-body);
  font-size: 1.125rem; /* 18px */
  font-weight: 500;
  color: var(--mm-dark-espresso, #2E1F1A);
  line-height: 1.4;
  padding-right: 1rem;
}

/* Minimal icon animation: 150-200ms */
.faq-item__icon {
  flex-shrink: 0;
  display: flex;
  align-items: center;
  justify-content: center;
  color: var(--mm-dark-espresso, #2E1F1A);
  transition: transform 200ms ease;
}

/* + rotates into × */
.faq-item__trigger[aria-expanded="true"] .faq-item__icon {
  transform: rotate(45deg);
}

/* 
  Performance Logic: 
  Bulletproof max-height + opacity
  150ms ultra-fast speed.
*/
.faq-item__answer {
  max-height: 0;
  opacity: 0;
  overflow: hidden;
  transition: max-height 150ms ease-out, opacity 150ms ease-out !important;
}

.faq-item__answer.is-open {
  max-height: 400px;
  opacity: 1;
}

/* Typography: Answer 15-16px, lighter opacity, 1.7 line-height */
.faq-item__answer-inner {
  padding-bottom: 1.5rem;
  font-size: 0.9375rem; /* 15px */
  color: var(--mm-dark-espresso, #2E1F1A);
  opacity: 0.8;
  line-height: 1.7;
}

.faq-item__answer-inner p {
  margin: 0;
}

.faq-section__footer {
  display: flex;
  flex-direction: column;
  align-items: flex-start;
  gap: var(--space-4);
}

.faq-section__cta-text {
  font-size: 1rem;
  color: var(--mm-dark-espresso, #2E1F1A);
  opacity: 0.8;
}
</style>

<script>
document.addEventListener('DOMContentLoaded', function () {
  var accordion = document.getElementById('FaqAccordion-{{ section.id }}');
  if (!accordion) return;

  var triggers = accordion.querySelectorAll('.faq-item__trigger');

  triggers.forEach(function (btn) {
    btn.addEventListener('click', function () {
      var isExpanded = this.getAttribute('aria-expanded') === 'true';
      var answer = document.getElementById(this.getAttribute('aria-controls'));

      // ONLY ONE OPEN AT A TIME: Close all others automatically
      triggers.forEach(function (otherBtn) {
        if (otherBtn !== btn) {
          otherBtn.setAttribute('aria-expanded', 'false');
          var otherAnswer = document.getElementById(otherBtn.getAttribute('aria-controls'));
          if (otherAnswer) {
            otherAnswer.classList.remove('is-open');
            otherAnswer.setAttribute('aria-hidden', 'true');
          }
        }
      });

      // Toggle current
      this.setAttribute('aria-expanded', String(!isExpanded));
      if (answer) {
        answer.classList.toggle('is-open', !isExpanded);
        answer.setAttribute('aria-hidden', String(isExpanded));
      }
    });
  });
});
</script>

