{% comment %}
  Section: Related Products
  Shown below PDP - curated or algorithm-driven
{% endcomment %}

{%- if recommendations.performed? and recommendations.products.size > 0 -%}
  <section class="related-products section-padding bg-murmur">
    <div class="container">
      <div class="section-heading text-center" style="margin-bottom: 60px;">
        {%- if section.settings.heading != blank -%}
          <h2 style="font-family: 'Cormorant Garamond', Georgia, serif; font-size: 2.2rem; font-weight: 500; color: var(--mm-deep-garnet);">{{ section.settings.heading }}</h2>
        {%- endif -%}
        <p style="font-size: 11px; color: var(--mm-dark-espresso); letter-spacing: 0.15em; text-transform: uppercase; font-weight: 600; opacity: 0.6; margin-top: 8px;">Pairs beautifully with your selection</p>
      </div>
      <div class="product-grid" style="row-gap: 60px;">
        {%- for product in recommendations.products limit: section.settings.products_count -%}
          {% render 'product-card', product: product %}
        {%- endfor -%}
      </div>
    </div>
  </section>
{%- endif -%}

<style>
.related-products.bg-murmur {
  background-color: var(--mm-soft-blush);
  border-top: 1px solid rgba(46,31,26,0.05);
}

.related-products .product-grid {
  display: grid;
  grid-template-columns: repeat(4, 1fr);
  gap: var(--space-6);
  row-gap: 60px;
  margin-bottom: var(--space-8);
}

/* Ensure no child can span multiple columns */
.related-products .product-grid > * {
  grid-column: span 1 !important;
  width: 100% !important;
}

@media (max-width: 768px) {
  .related-products .product-grid {
    grid-template-columns: repeat(2, 1fr);
    gap: var(--space-4);
    row-gap: 40px;
  }
  .related-products .section-heading h2 {
    font-size: 1.8rem !important;
  }
}

@media (min-width: 769px) and (max-width: 1023px) {
  .related-products .product-grid {
    grid-template-columns: repeat(3, 1fr);
  }
}
</style>

{% schema %}
{
  "name": "Related products",
  "settings": [
    {
      "type": "text",
      "id": "heading",
      "label": "Heading",
      "default": "You Might Also Like"
    },
    {
      "type": "range",
      "id": "products_count",
      "min": 2,
      "max": 8,
      "step": 1,
      "default": 4,
      "label": "Products to show"
    }
  ]
}
{% endschema %}
