{% comment %}
  Section: Footer
  - Brand column + 3 link columns + newsletter + social + payment icons
  - Each link column managed via footer-column blocks
{% endcomment %}

<footer class="site-footer" role="contentinfo">
  <div class="container">
    <!-- Top: Brand + Columns -->
    <div class="footer__top">
      <!-- Brand Column -->
      <div class="footer__brand">
        {%- if section.settings.logo != blank -%}
          <a href="{{ routes.root_url }}" class="footer__logo">
            <img
              src="{{ section.settings.logo | image_url: width: 160 }}"
              alt="{{ shop.name }}"
              width="120"
              height="40"
              loading="lazy"
            >
          </a>
        {%- else -%}
          <a href="{{ routes.root_url }}" class="footer__logo-icon" style="display: flex; align-items: center; gap: 12px; text-decoration: none; margin-bottom: var(--space-4);">
            <img
              src="{{ 'MicandMac_Monogram.webp' | asset_url }}"
              alt="Mic & Mac"
              width="36"
              height="36"
              loading="lazy"
            >
            <span style="font-family: var(--font-display); font-size: 20px; font-weight: 500; color: #fff; letter-spacing: 0.1em; text-transform: uppercase;">MIC &amp; MAC</span>
          </a>
        {%- endif -%}

        <p class="footer__brand-desc">
          Clean, conscious skincare crafted for daily care.
        </p>

        <div class="footer__contact" style="margin-top: 32px;">
          <h4 style="font-family: var(--font-display); font-size: 17px; font-weight: 600; color: #fff; letter-spacing: 0.05em; margin-bottom: 8px;">Need help?</h4>
          <a href="mailto:care@micandmacstores.com" style="display: block; font-size: var(--text-sm); color: rgba(255,255,255,0.95); text-decoration: none; margin-bottom: 8px; transition: color 0.3s;">care@micandmacstores.com</a>
          <a href="tel:+917339663196" style="display: block; font-size: var(--text-sm); color: rgba(255,255,255,0.95); text-decoration: none; margin-bottom: 16px; transition: color 0.3s;">+91 73396 63196</a>
        </div>

        <a href="/pages/contact" class="btn btn--secondary btn--outline" style="border-radius: var(--radius-sm); padding: 10px 28px; font-size: 13px; display: inline-flex; align-items: center; border: 1px solid rgba(255,255,255,0.4); color: #fff; background: transparent; transition: all var(--transition-fast); margin-bottom: 12px;">
          Contact Us <span style="margin-left: 6px;">&rarr;</span>
        </a>

        <div class="footer__social" style="display: flex; gap: var(--space-4); align-items: center;">
          {%- if section.settings.instagram != blank -%}
            <a href="{{ section.settings.instagram }}" target="_blank" rel="noopener" aria-label="Instagram" class="footer__social-link" style="display: inline-flex; align-items: center; gap: 6px; font-size: 14px; color: rgba(255,255,255,0.85); text-decoration: none;">
              <i class="fa-brands fa-instagram" style="font-size: 18px;"></i> <span>Instagram</span>
            </a>
          {%- else -%}
            <a href="#" aria-label="Instagram" class="footer__social-link" style="display: inline-flex; align-items: center; gap: 6px; font-size: 14px; color: rgba(255,255,255,0.85); text-decoration: none;">
              <i class="fa-brands fa-instagram" style="font-size: 18px;"></i> <span>Instagram</span>
            </a>
          {%- endif -%}
          {%- if section.settings.whatsapp != blank -%}
            <a href="https://wa.me/{{ section.settings.whatsapp }}" target="_blank" rel="noopener" aria-label="WhatsApp" class="footer__social-link" style="display: inline-flex; align-items: center; gap: 6px; font-size: 14px; color: rgba(255,255,255,0.85); text-decoration: none;">
              <i class="fa-brands fa-whatsapp" style="font-size: 18px;"></i> <span>WhatsApp</span>
            </a>
          {%- else -%}
             <a href="#" aria-label="WhatsApp" class="footer__social-link" style="display: inline-flex; align-items: center; gap: 6px; font-size: 14px; color: rgba(255,255,255,0.85); text-decoration: none;">
               <i class="fa-brands fa-whatsapp" style="font-size: 18px;"></i> <span>WhatsApp</span>
             </a>
          {%- endif -%}
        </div>
      </div>

      <!-- Link Columns -->
      <div class="footer__col">
        <h4 class="footer__col-title">Shop</h4>
        <ul class="footer__col-links">
          <li><a href="{{ routes.all_products_collection_url }}" class="footer__col-link">All Products</a></li>
          <li><a href="{{ routes.all_products_collection_url }}/glowing-bar" class="footer__col-link">Glowing Bars</a></li>
          <li><a href="{{ routes.all_products_collection_url }}/lip-care" class="footer__col-link">Lip Care</a></li>
        </ul>
      </div>

      <div class="footer__col">
        <h4 class="footer__col-title">Brand</h4>
        <ul class="footer__col-links">
          <li><a href="/pages/our-story" class="footer__col-link">Our Story</a></li>
        </ul>
      </div>

      <div class="footer__col">
        <h4 class="footer__col-title">Support</h4>
        <ul class="footer__col-links">
          <li><a href="/pages/track-order" class="footer__col-link">Track Order</a></li>
          <li><a href="/policies/shipping-policy" class="footer__col-link">Shipping</a></li>
          <li><a href="/policies/refund-policy" class="footer__col-link">Returns</a></li>
          <li><a href="/pages/faq" class="footer__col-link">FAQ</a></li>
        </ul>
      </div>
    </div>
    <!-- /.footer__top -->

    <!-- Trust seals row -->
    <div class="footer__trust-seals" style="gap: 20px;">
      <span class="footer__seal">✦   Lab-Certified</span>
      <span class="footer__seal">✦   Sulfate-Free</span>
      <span class="footer__seal">✦   Cruelty-Free</span>
      <span class="footer__seal">✦   Made in India</span>
    </div>
  </div>

  <div class="footer__giant-brand">MIC & MAC</div>

  <div class="container">
    <div class="footer__bottom">
      <p class="footer__copyright">
        &copy; 2026 Mic & Mac. All rights reserved. <span class="footer__copyright-divider">|</span> Crafted by
        <a href="https://mergex.in" target="_blank" rel="noopener" class="footer__mergex-link">Mergex</a>
      </p>

      <div class="footer__policy-links">
        <a href="{{ shop.privacy_policy.url }}">Privacy</a>
        <a href="{{ shop.refund_policy.url }}">Returns</a>
        <a href="{{ shop.shipping_policy.url }}">Shipping</a>
        <a href="{{ shop.terms_of_service.url }}">Terms</a>
        <a href="/policies/cookie-policy">Cookies</a>
      </div>

      {%- if section.settings.show_payment_icons -%}
        <div class="footer__payment" title="Secured by Razorpay" style="display: flex; align-items: center; gap: var(--space-6);">
          <div style="display: flex; align-items: center; gap: var(--space-2);">
            {{ 'upi' | payment_type_svg_tag: class: 'footer__payment-icon' }}
            {{ 'google_pay' | payment_type_svg_tag: class: 'footer__payment-icon' }}
            {{ 'visa' | payment_type_svg_tag: class: 'footer__payment-icon' }}
            {{ 'master' | payment_type_svg_tag: class: 'footer__payment-icon' }}
            {{ 'rupay' | payment_type_svg_tag: class: 'footer__payment-icon' }}
          </div>
          
          <a href="#MainContent" class="footer__back-to-top" aria-label="Back to top" onclick="window.scrollTo({top: 0, behavior: 'smooth'}); return false;">
            <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M18 15l-6-6-6 6"/></svg>
          </a>
        </div>
      {%- else -%}
        <a href="#MainContent" class="footer__back-to-top" aria-label="Back to top" onclick="window.scrollTo({top: 0, behavior: 'smooth'}); return false;">
          <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M18 15l-6-6-6 6"/></svg>
        </a>
      {%- endif -%}
    </div>
  </div>
</footer>

<style>
  /* ── Zero the footer's own Shopify wrapper top spacing ── */
  #shopify-section-footer {
    margin-top: 0 !important;
    padding-top: 0 !important;
  }

  .site-footer {
    position: relative;
    background: linear-gradient(to bottom, var(--mm-deep-garnet), var(--mm-dark-espresso));
    background-size: cover;
    background-position: center center;
    background-repeat: no-repeat;
    background-color: #3b1f25;
    overflow: hidden;
    color: rgba(255,255,255,0.65);
    padding-top: var(--space-8);
    padding-bottom: var(--space-8);
    margin-top: 0;
  }

  .site-footer::before {
    content: "";
    position: absolute;
    inset: 0;
    background: rgba(58, 31, 37, 0.9); /* Replaced gradient overlay with a flat dark mask for readability */
    pointer-events: none;
    z-index: 1;
  }



  /* Ensure footer content sits above overlay pseudo-elements */
  .site-footer > * {
    position: relative;
    z-index: 2;
  }

  @keyframes foamFloat {
    0% { transform: translateY(0px); }
    50% { transform: translateY(-10px); }
    100% { transform: translateY(0px); }
  }

  .footer__top {
    display: grid;
    grid-template-columns: 2fr 1fr 1fr 1fr;
    gap: var(--space-8);
    padding-bottom: var(--space-6);
  }

  .footer__logo-icon {
    display: block;
    margin-bottom: var(--space-4);
    transition: opacity 0.3s ease;
  }

  .footer__logo-icon:hover {
    opacity: 0.8;
  }

  .footer__logo-icon img {
    display: block;
    filter: brightness(0) invert(1);
  }

  .footer__brand-desc {
    font-size: 16px;
    line-height: 1.7;
    color: rgba(255,255,255,0.95);
    max-width: 100%;
    margin-bottom: var(--space-2);
  }

  .footer__ritual {
    font-family: var(--font-display);
    font-size: 13px;
    font-style: italic;
    color: rgba(255,255,255,0.6);
    margin-top: 8px;
    margin-bottom: var(--space-5);
  }

  .footer__social {
    display: flex;
    gap: var(--space-3);
  }

  .footer__social-link {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    color: #fff;
    font-size: 20px;
    transition: all var(--transition-fast);
  }

  .footer__social-link:hover {
    color: #fff;
    transform: translateY(-2px);
  }

  .footer__col {
    padding-top: 0;
  }

  .footer__col-title {
    font-family: var(--font-display);
    font-size: 14px;
    font-weight: 700;
    letter-spacing: 0.18em;
    text-transform: uppercase;
    color: #fff;
    margin-bottom: var(--space-5);
  }

  .footer__col-links {
    display: flex;
    flex-direction: column;
    gap: var(--space-3);
  }

  .footer__col-link {
    display: inline-block;
    font-size: var(--text-sm);
    color: rgba(255,255,255,0.95);
    transition: all var(--transition-fast);
  }

  .footer__col-link:hover {
    color: var(--color-gold);
    transform: translateX(2px);
  }

  /* Back to Top */
  .footer__back-to-top {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    width: 40px;
    height: 40px;
    border: 1px solid rgba(255,255,255,0.15);
    border-radius: 50%;
    color: rgba(255,255,255,0.6);
    transition: all var(--transition-base);
    text-decoration: none;
  }

  .footer__back-to-top:hover {
    border-color: #fff;
    color: #fff;
    background: rgba(255,255,255,0.05);
    transform: translateY(-3px);
  }

  /* Trust seals */
  .footer__trust-seals {
    display: flex;
    flex-wrap: wrap;
    align-items: center;
    justify-content: center;
    gap: var(--space-3);
    padding: var(--space-5) 0;
    margin-bottom: var(--space-6);
  }

  .footer__seal {
    font-family: var(--font-body);
    font-size: 10px;
    font-weight: 500;
    letter-spacing: 0.12em;
    text-transform: uppercase;
    color: rgba(255,255,255,0.45);
    opacity: 0.6;
  }

  .footer__seal-divider {
    color: rgba(255,255,255,0.2);
    font-size: 10px;
  }

  /* Bottom bar */
  .footer__bottom {
    display: flex;
    align-items: center;
    justify-content: space-between;
    flex-wrap: wrap;
    gap: var(--space-4);
    padding-top: var(--space-4);
  }

  .footer__copyright {
    font-size: var(--text-xs);
    color: rgba(255,255,255,0.35);
    line-height: 1;
  }

  .footer__copyright-divider {
    margin: 0 4px;
    color: rgba(255,255,255,0.15);
  }

  .footer__mergex-link {
    color: var(--color-white);
    font-weight: 300;
    letter-spacing: 0.1em;
    text-decoration: none;
    transition: color var(--transition-fast);
  }

  .footer__mergex-link:hover {
    color: var(--color-gold);
  }

  /* Operational status */
  .footer__status {
    display: flex;
    align-items: center;
    gap: 6px;
  }

  .footer__status-dot {
    width: 7px;
    height: 7px;
    border-radius: 50%;
    background: #4ade80;
    flex-shrink: 0;
    animation: mm-pulse 2s cubic-bezier(0.4, 0, 0.6, 1) infinite;
    box-shadow: 0 0 0 0 rgba(74, 222, 128, 0.4);
  }

  @keyframes mm-pulse {
    0% { transform: scale(0.95); box-shadow: 0 0 0 0 rgba(74, 222, 128, 0.7); opacity: 1; }
    70% { transform: scale(1); box-shadow: 0 0 0 6px rgba(74, 222, 128, 0); opacity: 0.6; }
    100% { transform: scale(0.95); box-shadow: 0 0 0 0 rgba(74, 222, 128, 0); opacity: 1; }
  }

  .footer__status-text {
    font-family: var(--font-body);
    font-size: 10px;
    letter-spacing: 0.06em;
    color: rgba(255,255,255,0.4);
  }

  .footer__policy-links {
    display: flex;
    gap: var(--space-4);
  }

  .footer__policy-links a {
    font-size: var(--text-xs);
    color: rgba(255,255,255,0.35);
    transition: color var(--transition-fast);
  }

  .footer__policy-links a:hover {
    color: var(--color-gold);
  }

  .footer__payment {
    display: flex;
    align-items: center;
    gap: var(--space-2);
    opacity: 0.5;
  }

  .footer__payment-icon {
    height: 20px;
    width: auto;
  }

  /* Responsive */
  @media (max-width: 1023px) {
    .footer__top {
      grid-template-columns: 1fr 1fr;
      gap: var(--space-8);
    }
  }

  @media (max-width: 639px) {
    .footer__top {
      grid-template-columns: 1fr;
      gap: var(--space-8);
    }
    .footer__bottom {
      flex-direction: column;
      text-align: center;
    }
  }

  .footer__giant-brand {
    width: 100%;
    text-align: center;
    font-family: var(--font-display);
    font-size: clamp(4rem, 15vw, 22rem);
    font-weight: 300;
    color: rgba(255, 255, 255, 0.015);
    line-height: 0.7;
    letter-spacing: 0.05em;
    text-transform: uppercase;
    pointer-events: none;
    user-select: none;
    padding-bottom: 0px;
    margin-top: 10px;
  }
</style>

{% schema %}
{
  "name": "Footer",
  "limit": 1,
  "settings": [
    {
      "type": "header",
      "content": "Brand"
    },
    {
      "type": "image_picker",
      "id": "logo",
      "label": "Footer logo (optional)"
    },
    {
      "type": "textarea",
      "id": "brand_desc",
      "label": "Brand description",
      "default": "Artisan-formulated, lab-certified skincare. Born in Coimbatore. Honest ingredients. Gentle results."
    },
    {
      "type": "header",
      "content": "Social links"
    },
    {
      "type": "url",
      "id": "instagram",
      "label": "Instagram URL"
    },
    {
      "type": "url",
      "id": "facebook",
      "label": "Facebook URL"
    },
    {
      "type": "url",
      "id": "youtube",
      "label": "YouTube URL"
    },
    {
      "type": "text",
      "id": "whatsapp",
      "label": "WhatsApp number (country code, no +)",
      "placeholder": "919876543210"
    },
    {
      "type": "header",
      "content": "Newsletter"
    },
    {
      "type": "checkbox",
      "id": "show_newsletter",
      "label": "Show newsletter signup",
      "default": true
    },
    {
      "type": "text",
      "id": "newsletter_heading",
      "label": "Newsletter heading",
      "default": "Get 15% off your first order"
    },
    {
      "type": "text",
      "id": "newsletter_sub",
      "label": "Newsletter subtext",
      "default": "Plus skincare education and early access to new formulas. No spam, ever."
    },
    {
      "type": "header",
      "content": "Bottom bar"
    },
    {
      "type": "checkbox",
      "id": "show_payment_icons",
      "label": "Show payment icons",
      "default": true
    }
  ],
  "blocks": [
    {
      "type": "link_column",
      "name": "Link column",
      "limit": 4,
      "settings": [
        {
          "type": "text",
          "id": "heading",
          "label": "Column heading"
        },
        {
          "type": "text",
          "id": "link_1_label",
          "label": "Link 1 label"
        },
        {
          "type": "url",
          "id": "link_1_url",
          "label": "Link 1 URL"
        },
        {
          "type": "text",
          "id": "link_2_label",
          "label": "Link 2 label"
        },
        {
          "type": "url",
          "id": "link_2_url",
          "label": "Link 2 URL"
        },
        {
          "type": "text",
          "id": "link_3_label",
          "label": "Link 3 label"
        },
        {
          "type": "url",
          "id": "link_3_url",
          "label": "Link 3 URL"
        },
        {
          "type": "text",
          "id": "link_4_label",
          "label": "Link 4 label"
        },
        {
          "type": "url",
          "id": "link_4_url",
          "label": "Link 4 URL"
        },
        {
          "type": "text",
          "id": "link_5_label",
          "label": "Link 5 label"
        },
        {
          "type": "url",
          "id": "link_5_url",
          "label": "Link 5 URL"
        }
      ]
    }
  ],
  "presets": [
    {
      "name": "Footer"
    }
  ]
}
{% endschema %}
