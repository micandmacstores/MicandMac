{% comment %}
  Section: Main Product (PDP) - Redesigned
  Structure:
    1. Hero: 60/40 grid - vertical gallery | product content
    2. Why It Works - benefit strip
    3. Ingredient Story - full-width (product-ingredients section)
    4. How to Use - numbered steps
    5. Social Proof - editorial pull-quotes
    6. Better Together - combo cards
    7. FAQ - accordion
    8. Sticky ATC (fixed bottom bar)
{% endcomment %}

{%- liquid
  assign current_variant = product.selected_or_first_available_variant
  assign avg_rating = product.metafields.reviews.rating.value
  assign review_count = product.metafields.reviews.rating_count.value
  assign benefits_line = product.metafields.custom.benefits_line
-%}

<!-- ============================================================
     SECTION 1: HERO - 60/40 Gallery | Content
     ============================================================ -->
<div class="pdp section-padding" id="PdpHero">
  <div class="container">

    <!-- Standard breadcrumb -->
    {% render 'breadcrumb' %}

    <div class="pdp__layout">

      <!-- LEFT: Gallery (60%) -->
      <div class="pdp__gallery">
        {% render 'product-gallery', product: product %}
      </div>

      <!-- RIGHT: Content (40%) -->
      <div class="pdp__content">

        <!-- Vendor -->
        {%- if product.vendor != blank and section.settings.show_vendor -%}
          <p class="pdp__vendor eyebrow" style="margin-bottom:var(--space-3);">{{ product.vendor }}</p>
        {%- endif -%}

        <!-- Title -->
        <h1 class="pdp__title">{{ product.title | split: '|' | first }}</h1>

        <!-- Star rating -->
        {%- assign review_count_num = review_count | plus: 0 -%}
        {%- if review_count_num > 0 -%}
          <div class="pdp__rating">
            {% render 'star-rating', rating: avg_rating, count: review_count_num, size: 'md' %}
          </div>
        {%- endif -%}

        <!-- Micro benefit line -->
        {%- if benefits_line != blank -%}
          <p class="pdp__micro-line">{{ benefits_line }}</p>
        {%- else -%}
          <p class="pdp__micro-line">Deep hydration &bull; Gentle cleansing &bull; Artisan-crafted</p>
        {%- endif -%}

        <!-- Price -->
        <div class="pdp__price" id="PdpPrice">
          {% render 'price', variant: current_variant %}
        </div>

        <!-- Inline Trust Strip -->
        {% render 'product-trust' %}

        <!-- Urgency badge -->
        {%- liquid
          assign badge_text = "Popular choice"
          if product.tags contains 'Bestseller' or product.tags contains 'bestseller'
            assign badge_text = "Bestseller"
          elsif product.tags contains 'New Arrival' or product.tags contains 'new-arrival' or product.tags contains 'New arrival'
            assign badge_text = "New Arrival"
          elsif product.variants.first.inventory_quantity <= 10 and product.variants.first.inventory_quantity > 0
            assign badge_text = "Only " | append: product.variants.first.inventory_quantity | append: " left"
          endif
        -%}
        <div class="pdp__urgency">{{ badge_text }}</div>

        <!-- Product Form (Add to Bag + Buy Now) -->
        {% render 'product-form', product: product, section: section %}

        <!-- Short Description (filtered to remove legacy "Our Actives" HTML) -->
        {%- liquid
          assign raw_desc = product.description | strip_html
          assign clean_desc = raw_desc

          if raw_desc contains 'Our Actives'
            assign parts = raw_desc | split: 'Our Actives'
            assign clean_desc = parts | first
          endif

          if clean_desc contains 'Powered by'
            assign parts2 = clean_desc | split: 'Powered by'
            assign clean_desc = parts2 | first
          endif

          assign clean_desc = clean_desc | strip
        -%}
        {%- if clean_desc != blank -%}
          <div class="pdp__description rte" style="margin-top: var(--space-6);">
            {{ clean_desc }}
          </div>
        {%- endif -%}


      </div><!-- /pdp__content -->
    </div><!-- /pdp__layout -->
  </div>
</div>


<!-- ============================================================
     SECTION 2: WHY IT WORKS - Benefit Strip
     ============================================================ -->
<div class="pdp-benefits">
  <div class="container">
    <div class="pdp-benefits__layout">
      <div>
        <p class="pdp-benefits__eyebrow">Why it works</p>
        <h2 class="pdp-benefits__title">Formulated to deliver,<br>not just promise</h2>
      </div>
      <ul class="pdp-benefits__list">
        {%- if product.metafields.custom.benefits != blank -%}
          {%- assign benefit_lines = product.metafields.custom.benefits | split: '|' -%}
          {%- for line in benefit_lines -%}
            <li class="pdp-benefits__item">
              <div class="pdp-benefits__accent" aria-hidden="true"></div>
              <span class="pdp-benefits__text">{{ line | strip }}</span>
            </li>
          {%- endfor -%}
        {%- else -%}
          <li class="pdp-benefits__item">
            <div class="pdp-benefits__accent" aria-hidden="true"></div>
            <span class="pdp-benefits__text">Deep cleans without stripping natural moisture</span>
          </li>
          <li class="pdp-benefits__item">
            <div class="pdp-benefits__accent" aria-hidden="true"></div>
            <span class="pdp-benefits__text">Supports the skin's natural pH balance</span>
          </li>
          <li class="pdp-benefits__item">
            <div class="pdp-benefits__accent" aria-hidden="true"></div>
            <span class="pdp-benefits__text">Leaves skin soft and nourished - never tight</span>
          </li>
          <li class="pdp-benefits__item">
            <div class="pdp-benefits__accent" aria-hidden="true"></div>
            <span class="pdp-benefits__text">Free from sulphates, parabens, and synthetic fragrance</span>
          </li>
        {%- endif -%}
      </ul>
    </div>
  </div>
</div>




{% schema %}
{
  "name": "Main product",
  "tag": "section",
  "settings": [
    {
      "type": "checkbox",
      "id": "show_vendor",
      "label": "Show vendor",
      "default": false
    },
    {
      "type": "checkbox",
      "id": "show_buy_now",
      "label": "Show Buy Now button",
      "default": true
    },
    {
      "type": "checkbox",
      "id": "show_notify_me",
      "label": "Show notify-me form for sold-out variants",
      "default": true
    },
    {
      "type": "checkbox",
      "id": "show_related",
      "label": "Show related products below",
      "default": true
    }
  ]
}
{% endschema %}
