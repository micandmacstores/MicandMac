<!doctype html>
<html lang="{{ request.locale.iso_code }}">
<head>
 {%- capture ecom_header_content -%}{%- render 'ecom_header' -%}{%- endcapture -%}{%- unless ecom_header_content contains 'Liquid error' -%}{{ ecom_header_content }}{%- endunless -%}
  <meta name="theme-color" content="#4B2A31">

  {%- render 'meta-tags' -%}

  {{ content_for_header }}

  <!-- Google Fonts: Great Vibes (script) + Cormorant Garamond (display) + Inter (body) -->
  {% comment %}theme-check-disable{% endcomment %}
  <link rel="preconnect" href="https://fonts.googleapis.com">
  <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
  <link href="https://fonts.googleapis.com/css2?family=Great+Vibes&family=Cormorant+Garamond:ital,wght@0,300;0,400;0,600;1,300;1,400&family=Inter:wght@400;500;600&display=swap" rel="stylesheet">
  
  <!-- Font Awesome 6.4.2 -->
  <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.4.2/css/all.min.css" integrity="sha512-z3gLpd7yknf1YoNbCzqRKc4qyor8gaKU1qmn+CShxbuBusANI9QpRohGBreCFkKxLhei6S9CQXFEbbKuqLg0DA==" crossorigin="anonymous" referrerpolicy="no-referrer" />
  {% comment %}theme-check-enable{% endcomment %}

  <!-- Modular CSS - load order matters (tokens → reset → … → animations) -->
  {{ 'tokens.css'     | asset_url | stylesheet_tag: preload: true }}
  {{ 'reset.css'      | asset_url | stylesheet_tag: preload: true }}
  {{ 'typography.css' | asset_url | stylesheet_tag: preload: true }}
  {{ 'layout.css'     | asset_url | stylesheet_tag: preload: true }}
  {{ 'search-overlay.css' | asset_url | stylesheet_tag }}
  {{ 'components.css' | asset_url | stylesheet_tag }}
  {{ 'header.css'     | asset_url | stylesheet_tag }}
  {{ 'mobile-nav.css' | asset_url | stylesheet_tag }}
  {{ 'animations.css' | asset_url | stylesheet_tag }}
  {{ 'theme.css'      | asset_url | stylesheet_tag }}
  {{ 'pdp.css'        | asset_url | stylesheet_tag }}
  {{ 'account.css'    | asset_url | stylesheet_tag }}


  {%- comment -%} Favicon set via asset files - see RealFaviconGenerator block below {%- endcomment -%}
  {%- comment -%} Favicon set via asset files - see RealFaviconGenerator block below {%- endcomment -%}

  <!-- RealFaviconGenerator HTML markups -->
  <link rel="icon" type="image/png" href="{{ 'favicon-96x96.png' | asset_url }}" sizes="96x96" />
  <link rel="icon" type="image/svg+xml" href="{{ 'favicon.svg' | asset_url }}" />
  <link rel="shortcut icon" href="{{ 'favicon.ico' | asset_url }}" />
  <link rel="apple-touch-icon" sizes="180x180" href="{{ 'apple-touch-icon.png' | asset_url }}" />
  <meta name="apple-mobile-web-app-title" content="Mic & Mac" />
  <link rel="manifest" href="{{ 'site.webmanifest' | asset_url }}" />
</head>

<body class="template-{{ template.name }}{% if template.suffix %} template-{{ template.name }}-{{ template.suffix }}{% endif %}">

  <!-- Skip to content (accessibility) -->
  <a class="skip-to-content" href="#MainContent">Skip to content</a>

  <!-- Announcement Bar Section -->
  {%- section 'announcement-bar' -%}

  <!-- Header -->
  {%- section 'header' -%}

  <!-- Cart Drawer -->
  {%- section 'cart-drawer' -%}

  {%- render 'search-overlay' -%}

  <!-- Main Content -->
  <main id="MainContent" role="main" tabindex="-1">
    {{ content_for_layout }}
  </main>

  <!-- Footer -->
  {%- section 'footer' -%}

  <!-- Global JS data (read by theme modules) -->
  <script>
    window.productHandle    = {{ product.handle | json | default: 'null' }};
    window.customerLoggedIn = {% if customer %}true{% else %}false{% endif %};
    window.wishlistSyncUrl  = '';
  </script>

  <!-- Global JS -->
  <script src="{{ 'theme.js' | asset_url }}" defer></script>

  <!-- Mobile Navigation JS (top bar, drawer, bottom dock) -->
  <script src="{{ 'mobile-nav.js' | asset_url }}" defer></script>

  <!-- Cart JS -->
  <script src="{{ 'cart.js' | asset_url }}" defer></script>

  <!-- Search Overlay JS -->
  <script src="{{ 'search-overlay.js' | asset_url }}" defer></script>

  <!-- Scroll Reveal Engine (CSS IntersectionObserver - no dependencies) -->
  <script src="{{ 'cinematic.js' | asset_url }}" defer></script>

  <!-- Inertial Smooth Scroll (desktop only; touch devices use native kinetic scroll) -->
  <script src="{{ 'smooth-scroll.js' | asset_url }}" defer></script>

  <!-- WhatsApp Sticky CTA -->
  {%- render 'whatsapp-sticky' -%}

{%- capture ecom_footer_content -%}{%- render 'ecom_footer' -%}{%- endcapture -%}{%- unless ecom_footer_content contains 'Liquid error' -%}{{ ecom_footer_content }}{%- endunless -%}</body>
</html>
