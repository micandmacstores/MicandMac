<!doctype html>
<html lang="{{ request.locale.iso_code }}">
  <head>
    {% # Inlined CSS Variables %}
    {% render 'css-variables' %}

    {% # Load and preload the critical CSS %}
    {{ 'critical.css' | asset_url | stylesheet_tag: preload: true }}

    {% # Social, title, etc. %}
    {% render 'meta-tags' %}

    {{ content_for_header }}

    <!-- RealFaviconGenerator HTML markups -->
    <link rel="icon" type="image/png" href="{{ 'favicon-96x96.png' | asset_url }}" sizes="96x96" />
    <link rel="icon" type="image/svg+xml" href="{{ 'favicon.svg' | asset_url }}" />
    <link rel="shortcut icon" href="{{ 'favicon.ico' | asset_url }}" />
    <link rel="apple-touch-icon" sizes="180x180" href="{{ 'apple-touch-icon.png' | asset_url }}" />
    <meta name="apple-mobile-web-app-title" content="Mic & Mac Glow Bars" />
    <link rel="manifest" href="{{ 'site.webmanifest' | asset_url }}" />
  </head>

  <body>
    {{ content_for_layout }}
  </body>
</html>
